@{
    Layout = null;
    ViewData["Title"] = "تسجيل دخول المسؤول";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — UniStay</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/admin-login.css">
</head>
<body>

    <!-- ── Background scene ── -->
    <div class="bg-scene">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
        <div class="geo geo-1"></div>
        <div class="geo geo-2"></div>
        <div class="geo geo-3"></div>
    </div>

    <!-- ── Login Card ── -->
    <div class="login-wrapper">
        <div class="login-card">

            <!-- Brand -->
            <div class="brand-mark">
                <div class="brand-icon">
                    <i class="fa-solid fa-building-columns"></i>
                </div>
                <div class="brand-name">UniStay</div>
                <div class="brand-sub">لوحة تحكم المسؤولين</div>
            </div>

            <!-- Error / Success alerts -->
            <div class="alert-box alert-error" id="alertError">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span id="alertErrorMsg">اسم المستخدم أو كلمة المرور غير صحيحة</span>
            </div>
            <div class="alert-box alert-success" id="alertSuccess">
                <i class="fa-solid fa-circle-check"></i>
                <span>تم تسجيل الدخول بنجاح، جاري التحويل…</span>
            </div>

            @if (TempData["Error"] != null)
            {
                <script>
                    document.addEventListener('DOMContentLoaded', () => showError("@TempData["Error"]")

                </script>
            }

            <!-- Form -->
            <form id="loginForm" asp-action="AdminLogin" asp-controller="Auth" method="post" novalidate>
                @Html.AntiForgeryToken()

                <!-- Username -->
                <div class="field-group" style="--delay:.3s">
                    <label class="field-label" for="username">
                        <i class="fa-solid fa-user-shield me-1" style="color:var(--gold)"></i>
                        اسم المستخدم
                    </label>
                    <div class="field-wrap">
                        <input type="text"
                               id="username"
                               name="Username"
                               class="form-control"
                               placeholder="أدخل اسم المستخدم"
                               autocomplete="username"
                               required />
                        <i class="fa-solid fa-at field-icon"></i>
                    </div>
                    <div class="invalid-feedback" id="usernameErr"></div>
                </div>

                <!-- Password -->
                <div class="field-group" style="--delay:.4s">
                    <label class="field-label" for="password">
                        <i class="fa-solid fa-lock me-1" style="color:var(--gold)"></i>
                        كلمة المرور
                    </label>
                    <div class="field-wrap">
                        <input type="password"
                               id="password"
                               name="Password"
                               class="form-control"
                               placeholder="أدخل كلمة المرور"
                               autocomplete="current-password"
                               required />
                        <i class="fa-solid fa-lock field-icon"></i>
                        <button type="button" class="toggle-pass" id="togglePass" title="إظهار / إخفاء">
                            <i class="fa-solid fa-eye" id="toggleIcon"></i>
                        </button>
                    </div>
                    <div class="invalid-feedback" id="passwordErr"></div>
                </div>

                <!-- Remember + Forgot -->
                <div class="row-extras">
                    <label class="remember-label">
                        <input type="checkbox" name="RememberMe" />
                        تذكرني
                    </label>
                    <a href="#" class="forgot-link">نسيت كلمة المرور؟</a>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn-login" id="submitBtn">
                    <span class="btn-text">
                        <i class="fa-solid fa-arrow-right-to-bracket me-2"></i>
                        تسجيل الدخول
                    </span>
                    <span class="btn-spinner">
                        <i class="fa-solid fa-spinner fa-spin"></i>
                    </span>
                </button>

                <div class="divider">نظام إدارة السكن الجامعي</div>

                <div class="card-footer-text">
                    UniStay &copy; @DateTime.Now.Year &nbsp;·&nbsp;
                    <span>جميع الحقوق محفوظة</span>
                </div>

            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // ── Helpers ──────────────────────────────────────────
        const $ = id => document.getElementById(id);

        function showError(msg) {
            $('alertErrorMsg').textContent = msg || 'اسم المستخدم أو كلمة المرور غير صحيحة';
            $('alertError').classList.add('show');
            $('alertSuccess').classList.remove('show');
        }

        function showSuccess() {
            $('alertSuccess').classList.add('show');
            $('alertError').classList.remove('show');
        }

        // ── Password toggle ───────────────────────────────────
        const toggle = $('togglePass');
        if (toggle) {
            toggle.addEventListener('click', () => {
                const inp  = $('password');
                const icon = $('toggleIcon');
                const show = inp.type === 'password';
                inp.type   = show ? 'text' : 'password';
                icon.className = show ? 'fa-solid fa-eye-slash' : 'fa-solid fa-eye';
            });
        }

        // ── Clear alerts on input ─────────────────────────────
        ['username', 'password'].forEach(id => {
            $(id).addEventListener('input', () => {
                $('alertError').classList.remove('show');
                $(id).classList.remove('is-invalid');
            });
        });

        // ── Client-side validation ────────────────────────────
        function validate() {
            let valid = true;

            const username = $('username').value.trim();
            const password = $('password').value;

            if (!username) {
                $('username').classList.add('is-invalid');
                $('usernameErr').textContent = '';

                valid = false;
            }

            if (!password) {
                $('password').classList.add('is-invalid');
                $('passwordErr').textContent = '';
                
                valid = false;
            } else if (password.length < 4) {
                $('password').classList.add('is-invalid');
                $('passwordErr').textContent = 'كلمة المرور قصيرة جداً';
                valid = false;
            }

            return valid;
        }

        // ── Form submit ───────────────────────────────────────
        $('loginForm').addEventListener('submit', function (e) {
            if (!validate()) {
                e.preventDefault();
                return;
            }

            const btn = $('submitBtn');
            btn.classList.add('loading');
            btn.disabled = true;
        });

        // ── Input focus gold glow ─────────────────────────────
        document.querySelectorAll('.form-control').forEach(input => {
            input.addEventListener('focus', () => {
                input.closest('.field-wrap').querySelector('.field-icon').style.color = 'var(--gold)';
            });
            input.addEventListener('blur', () => {
                input.closest('.field-wrap').querySelector('.field-icon').style.color = '';
            });
        });
    </script>
</body>
</html>
