@* Views/Shared/_AdminLayout.cshtml *@
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — UniStay Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        :root {
            --sidebar-w: 260px;
            --primary: #1a3c5e;
            --primary-light: #2a5298;
            --accent: #e8b84b;
            --bg: #f0f4f8;
            --sidebar-text: #cdd9e5;
            --sidebar-hover: rgba(255,255,255,.08);
        }

        body {
            background: var(--bg);
            font-family: 'Segoe UI', Tahoma, sans-serif;
        }

        /* ===== Sidebar ===== */
        #sidebar {
            width: var(--sidebar-w);
            min-height: 100vh;
            background: var(--primary);
            position: fixed;
            top: 0;
            right: 0;
            z-index: 1000;
            transition: transform .3s;
            display: flex;
            flex-direction: column;
        }

            #sidebar .brand {
                padding: 20px 18px;
                border-bottom: 1px solid rgba(255,255,255,.1);
            }

                #sidebar .brand h5 {
                    color: white;
                    margin: 0;
                    font-weight: 700;
                }

                #sidebar .brand small {
                    color: var(--accent);
                    font-size: .75rem;
                }

            #sidebar .admin-info {
                padding: 14px 18px;
                background: rgba(0,0,0,.2);
                display: flex;
                align-items: center;
                gap: 10px;
                border-bottom: 1px solid rgba(255,255,255,.08);
            }

        .admin-avatar {
            width: 38px;
            height: 38px;
            background: var(--accent);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: var(--primary);
            font-size: .85rem;
            flex-shrink: 0;
        }

        .admin-info .name {
            color: white;
            font-size: .85rem;
            font-weight: 600;
        }

        .admin-info .role-badge {
            font-size: .7rem;
            padding: 2px 8px;
            border-radius: 20px;
            display: inline-block;
            margin-top: 2px;
        }

        .role-supervisor {
            background: #dc3545;
            color: white;
        }

        .role-manager {
            background: #fd7e14;
            color: white;
        }

        .role-staff {
            background: #6c757d;
            color: white;
        }

        #sidebar nav {
            padding: 12px 0;
            flex: 1;
            overflow-y: auto;
        }

        .nav-section-title {
            color: rgba(255,255,255,.35);
            font-size: .68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 14px 18px 5px;
        }

        #sidebar .nav-link {
            color: var(--sidebar-text);
            padding: 10px 18px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-radius: 0;
            transition: all .2s;
            font-size: .88rem;
            text-decoration: none;
        }

            #sidebar .nav-link:hover,
            #sidebar .nav-link.active {
                background: var(--sidebar-hover);
                color: white;
                border-right: 3px solid var(--accent);
            }

            #sidebar .nav-link i {
                width: 18px;
                text-align: center;
                opacity: .8;
            }

            #sidebar .nav-link .badge-count {
                margin-right: auto;
                background: var(--accent);
                color: var(--primary);
                font-size: .68rem;
                padding: 2px 7px;
                border-radius: 20px;
                font-weight: 700;
            }

        /* ===== Main ===== */
        #main {
            margin-right: var(--sidebar-w);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        #topbar {
            background: white;
            padding: 12px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 1px 4px rgba(0,0,0,.08);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .topbar-title {
            font-weight: 700;
            color: var(--primary);
            font-size: 1.05rem;
        }

        #content {
            padding: 24px;
            flex: 1;
        }

        /* ===== Cards ===== */
        .stat-card {
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,.06);
            border-right: 4px solid transparent;
            transition: transform .2s;
        }

            .stat-card:hover {
                transform: translateY(-2px);
            }

            .stat-card .icon {
                width: 48px;
                height: 48px;
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.3rem;
            }

            .stat-card .number {
                font-size: 1.9rem;
                font-weight: 800;
                color: var(--primary);
            }

            .stat-card .label {
                color: #6c757d;
                font-size: .82rem;
            }

        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,.06);
        }

        .card-header {
            background: white;
            border-bottom: 1px solid #f0f0f0;
            padding: 16px 20px;
            font-weight: 700;
        }

        /* ===== Tables ===== */
        .table th {
            font-size: .8rem;
            text-transform: uppercase;
            color: #6c757d;
            font-weight: 700;
            border-top: none;
        }

        .table td {
            vertical-align: middle;
            font-size: .88rem;
        }

        .status-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: .75rem;
            font-weight: 600;
        }

        /* ===== Responsive ===== */
        @@media (max-width: 768px) {
            #sidebar

        {
            transform: translateX(100%);
        }

        #sidebar.show {
            transform: translateX(0);
        }

        #main {
            margin-right: 0;
        }

        }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div id="sidebar">
        <div class="brand">
            <h5>🏛️ UniStay</h5>
            <small>نظام إدارة السكن الجامعي</small>
        </div>

        <div class="admin-info">
            <div class="admin-avatar">
                @(Context.Session.GetString("AdminName")?[0].ToString() ?? "A")
            </div>
            <div>
                <div class="name">@Context.Session.GetString("AdminName")</div>
                @{
                    var role = Context.Session.GetString("AdminRole");
                    var roleClass = role == "Supervisor" ? "role-supervisor" : role == "Manager" ? "role-manager" : "role-staff";
                    var roleAr = role == "Supervisor" ? "مشرف عام" : role == "Manager" ? "مدير" : "موظف";
                }
                <span class="role-badge @roleClass">@roleAr</span>
            </div>
        </div>

        <nav>
            <!-- الرئيسية -->
            <div class="nav-section-title">الرئيسية</div>
            <a href="/Admin/Dashboard" class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
                <i class="fas fa-chart-pie"></i> لوحة التحكم
            </a>

            <!-- الطلاب -->
            <div class="nav-section-title">الطلاب</div>
            <a href="/Students/Index" class="nav-link">
                <i class="fas fa-users"></i> كل الطلاب
                <span class="badge-count" id="sb-students">...</span>
            </a>
            <a href="/Students/Pending" class="nav-link">
                <i class="fas fa-user-clock"></i> بانتظار المراجعة
                <span class="badge-count" id="sb-pending">...</span>
            </a>

            <!-- الطلبات -->
            @if (role != "Staff")
            {
                <div class="nav-section-title">الطلبات</div>
                <a href="/Applications/Index" class="nav-link">
                    <i class="fas fa-file-alt"></i> كل الطلبات
                </a>
                <a href="/Applications/Pending" class="nav-link">
                    <i class="fas fa-hourglass-half"></i> طلبات معلقة
                </a>
            }

            <!-- المباني والغرف -->
            <div class="nav-section-title">المسكن</div>
            <a href="/Rooms/Buildings" class="nav-link">
                <i class="fas fa-building"></i> المباني
            </a>
            <a href="/Rooms/Index" class="nav-link">
                <i class="fas fa-door-open"></i> الغرف
            </a>

            <!-- التقارير — Supervisor فقط -->
            @if (role == "Supervisor")
            {
                <div class="nav-section-title">الإدارة</div>
                <a href="/Reports/Index" class="nav-link">
                    <i class="fas fa-chart-bar"></i> التقارير
                </a>
                <a href="/Admin/Admins" class="nav-link">
                    <i class="fas fa-user-shield"></i> المسؤولون
                </a>
            }

            <!-- تسجيل الخروج -->
            <div class="nav-section-title"></div>
            <a href="/Auth/Logout" class="nav-link text-danger">
                <i class="fas fa-sign-out-alt"></i> تسجيل الخروج
            </a>
        </nav>
    </div>

    <!-- Main -->
    <div id="main">
        <div id="topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-sm btn-light d-md-none" onclick="document.getElementById('sidebar').classList.toggle('show')">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="topbar-title">@ViewData["Title"]</span>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="text-muted small">
                    <i class="fas fa-calendar-alt me-1"></i>
                    @DateTime.Now.ToString("dd/MM/yyyy")
                </span>
            </div>
        </div>

        <div id="content">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // تحديث الـ badges في الـ sidebar
        fetch('/Admin/SidebarCounts')
            .then(r => r.json())
            .then(d => {
                document.getElementById('sb-students').textContent = d.students;
                document.getElementById('sb-pending').textContent  = d.pending;
            }).catch(() => {});
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
