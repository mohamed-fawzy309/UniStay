@{
    ViewData["Title"] = "نتائج القبول";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css"
          crossorigin="anonymous" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Tajawal:wght@400;500;700&display=swap"
          rel="stylesheet" />

    <style>
        :root {
            --blue: #3b82f6;
            --blue-light: #60a5fa;
            --blue-dim: rgba(59,130,246,.15);
            --dark: #0b0f1a;
            --dark-card: #111827;
            --dark-input: #1a2236;
            --dark-border: #1f2d45;
            --text-muted: #6b7a99;
            --text-main: #e2e8f5;
            --success: #10b981;
            --success-dim: rgba(16,185,129,.15);
            --danger: #ef4444;
            --danger-dim: rgba(239,68,68,.12);
            --warn: #f59e0b;
            --warn-light: #fbbf24;
            --warn-dim: rgba(245,158,11,.15);
            --radius: 14px;
            --radius-sm: 8px;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: var(--dark);
            color: var(--text-main);
            min-height: 100vh;
            direction: rtl;
            overflow-x: hidden;
        }

        .bg-grid {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            background-image: linear-gradient(var(--dark-border) 1px, transparent 1px), linear-gradient(90deg, var(--dark-border) 1px, transparent 1px);
            background-size: 48px 48px;
            opacity: .35;
        }

        .bg-glow {
            position: fixed;
            width: 650px;
            height: 650px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(59,130,246,.11) 0%, transparent 70%);
            top: -180px;
            left: 50%;
            transform: translateX(-50%);
            pointer-events: none;
            z-index: 0;
            animation: glow-drift 8s ease-in-out infinite alternate;
        }

        @@keyframes glow-drift {
            from {
                transform: translateX(-50%) translateY(0);
            }

            to {
                transform: translateX(-50%) translateY(40px);
            }
        }

        .page-wrap {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 3.5rem 1rem 5rem;
        }

        .page-header {
            text-align: center;
            margin-bottom: 2.5rem;
            animation: fade-down .6s cubic-bezier(.22,1,.36,1) both;
        }

        .badge-label {
            display: inline-block;
            font-family: 'Cairo', sans-serif;
            font-size: .78rem;
            font-weight: 700;
            letter-spacing: .08em;
            color: var(--blue-light);
            background: var(--blue-dim);
            border: 1px solid rgba(59,130,246,.3);
            border-radius: 20px;
            padding: .3rem 1rem;
            margin-bottom: 1rem;
        }

        .page-header h1 {
            font-family: 'Cairo', sans-serif;
            font-weight: 900;
            font-size: clamp(1.9rem, 4.5vw, 3rem);
            line-height: 1.2;
        }

            .page-header h1 span {
                color: var(--blue-light);
            }

        .page-header p {
            color: var(--text-muted);
            font-size: 1.05rem;
            margin-top: .55rem;
        }

        .search-card {
            background: var(--dark-card);
            border: 1px solid var(--dark-border);
            border-radius: var(--radius);
            padding: 2.5rem;
            width: 100%;
            max-width: 540px;
            box-shadow: 0 24px 64px rgba(0,0,0,.4);
            animation: fade-up .65s cubic-bezier(.22,1,.36,1) .1s both;
        }

        .form-label-custom {
            display: block;
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .95rem;
            color: var(--text-main);
            margin-bottom: .55rem;
        }

            .form-label-custom span {
                color: var(--text-muted);
                font-size: .85rem;
                font-weight: 400;
            }

        .input-wrap {
            position: relative;
        }

        .input-icon {
            position: absolute;
            top: 50%;
            right: 1rem;
            transform: translateY(-50%);
            color: var(--text-muted);
            pointer-events: none;
            transition: color .2s;
        }

        .input-field {
            width: 100%;
            background: var(--dark-input);
            border: 1.5px solid var(--dark-border);
            border-radius: var(--radius-sm);
            color: var(--text-main);
            font-family: 'Tajawal', sans-serif;
            font-size: 1.1rem;
            padding: .95rem 3rem .95rem 1rem;
            outline: none;
            transition: border-color .25s, box-shadow .25s;
            direction: ltr;
            text-align: right;
            letter-spacing: .08em;
        }

            .input-field::placeholder {
                color: var(--text-muted);
                direction: rtl;
                letter-spacing: 0;
                font-size: .95rem;
            }

            .input-field:focus {
                border-color: var(--blue);
                box-shadow: 0 0 0 3px var(--blue-dim);
            }

                .input-field:focus ~ .input-icon {
                    color: var(--blue-light);
                }

            .input-field.invalid {
                border-color: var(--danger);
                box-shadow: 0 0 0 3px var(--danger-dim);
            }

        .row-hint {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: .45rem;
        }

        .field-error {
            color: var(--danger);
            font-size: .82rem;
            display: none;
            align-items: center;
            gap: .35rem;
        }

        .char-counter {
            font-size: .78rem;
            color: var(--text-muted);
            font-variant-numeric: tabular-nums;
            transition: color .2s;
        }

            .char-counter.done {
                color: var(--success);
            }

        .btn-search {
            width: 100%;
            background: var(--blue);
            border: none;
            border-radius: var(--radius-sm);
            color: #fff;
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: 1.05rem;
            padding: .95rem 1.5rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .6rem;
            transition: background .2s, transform .15s, box-shadow .2s;
            position: relative;
            overflow: hidden;
            margin-top: 1.75rem;
        }

            .btn-search::after {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg, rgba(255,255,255,.12) 0%, transparent 60%);
                pointer-events: none;
            }

            .btn-search:hover:not(:disabled) {
                background: var(--blue-light);
                box-shadow: 0 8px 24px rgba(59,130,246,.35);
                transform: translateY(-1px);
            }

            .btn-search:active:not(:disabled) {
                transform: translateY(0);
            }

            .btn-search:disabled {
                opacity: .7;
                cursor: not-allowed;
            }

        .spinner {
            width: 18px;
            height: 18px;
            border: 2.5px solid rgba(255,255,255,.35);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .65s linear infinite;
            display: none;
        }

        .btn-search.loading .spinner {
            display: block;
        }

        .btn-search.loading .btn-text {
            opacity: .65;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        #resultArea {
            width: 100%;
            max-width: 540px;
            margin-top: 1.75rem;
        }

        .result-card {
            background: var(--dark-card);
            border: 1px solid var(--dark-border);
            border-radius: var(--radius);
            overflow: hidden;
            animation: fade-up .5s cubic-bezier(.22,1,.36,1) both;
            box-shadow: 0 16px 48px rgba(0,0,0,.35);
        }

        .result-header {
            padding: 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

            .result-header.accepted {
                background: var(--success-dim);
                border-bottom: 1px solid rgba(16,185,129,.2);
            }

            .result-header.under_review {
                background: var(--warn-dim);
                border-bottom: 1px solid rgba(245,158,11,.25);
            }

        .result-icon {
            width: 54px;
            height: 54px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            flex-shrink: 0;
        }

            .result-icon.accepted {
                background: var(--success-dim);
            }

            .result-icon.under_review {
                background: var(--warn-dim);
            }

        .result-title {
            font-family: 'Cairo', sans-serif;
            font-weight: 900;
            font-size: 1.2rem;
        }

            .result-title.accepted {
                color: var(--success);
            }

            .result-title.under_review {
                color: var(--warn-light);
            }

        .result-subtitle {
            color: var(--text-muted);
            font-size: .9rem;
            margin-top: .15rem;
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .82rem;
            padding: .3rem .85rem;
            border-radius: 20px;
            margin-right: auto;
        }

            .status-pill.accepted {
                background: var(--success-dim);
                color: var(--success);
                border: 1px solid rgba(16,185,129,.3);
            }

            .status-pill.under_review {
                background: var(--warn-dim);
                color: var(--warn-light);
                border: 1px solid rgba(245,158,11,.35);
            }

        .pulse-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: currentColor;
            animation: blink 1.4s ease-in-out infinite;
        }

        @@keyframes blink {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: .25;
            }
        }

        .review-notice {
            margin: 0 1.5rem 1.25rem;
            background: var(--warn-dim);
            border: 1px solid rgba(245,158,11,.3);
            border-radius: var(--radius-sm);
            padding: .9rem 1.1rem;
            display: flex;
            align-items: flex-start;
            gap: .75rem;
        }

        .review-notice-icon {
            font-size: 1.3rem;
            flex-shrink: 0;
            margin-top: .05rem;
        }

        .review-notice-text {
            font-size: .9rem;
            color: var(--warn-light);
            line-height: 1.7;
        }

            .review-notice-text strong {
                font-family: 'Cairo', sans-serif;
                font-weight: 700;
                display: block;
                margin-bottom: .15rem;
            }

        .info-grid {
            padding: 1.5rem;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        @@media (max-width: 480px) {
            .info-grid {
                grid-template-columns: 1fr;
            }
        }

        .info-item {
            background: var(--dark-input);
            border: 1px solid var(--dark-border);
            border-radius: var(--radius-sm);
            padding: .85rem 1rem;
        }

        .info-label {
            font-size: .75rem;
            color: var(--text-muted);
            font-weight: 600;
            letter-spacing: .06em;
            margin-bottom: .3rem;
        }

        .info-value {
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: 1rem;
            color: var(--text-main);
        }

            .info-value.blue {
                color: var(--blue-light);
            }

            .info-value.green {
                color: var(--success);
            }

            .info-value.amber {
                color: var(--warn-light);
            }

        .notfound-card {
            background: var(--dark-card);
            border: 1px solid var(--dark-border);
            border-radius: var(--radius);
            padding: 2.75rem;
            text-align: center;
            animation: fade-up .45s cubic-bezier(.22,1,.36,1) both;
        }

        .notfound-icon {
            font-size: 3rem;
            display: block;
            margin-bottom: 1rem;
        }

        .notfound-card h3 {
            font-family: 'Cairo', sans-serif;
            font-weight: 800;
            font-size: 1.2rem;
            color: var(--text-main);
            margin-bottom: .5rem;
        }

        .notfound-card p {
            color: var(--text-muted);
            font-size: .93rem;
            line-height: 1.8;
        }

        @@keyframes fade-down {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fade-up {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (max-width: 576px) {
            .search-card {
                padding: 1.75rem 1.25rem;
            }
        }
    </style>
</head>
<body>

    <div class="bg-grid" aria-hidden="true"></div>
    <div class="bg-glow" aria-hidden="true"></div>

    <div class="page-wrap">

        <header class="page-header">
            <div class="badge-label">🎓 بوابة القبول الجامعي</div>
            <h1>الاستعلام عن <span>نتيجة القبول</span></h1>
            <p>أدخل رقمك القومي للاستعلام عن حالة قبولك</p>
        </header>

        <div class="search-card">
            <label for="nationalId" class="form-label-custom">
                الرقم القومي
                <span>— 14 رقم</span>
            </label>

            <div class="input-wrap">
                <input type="text"
                       id="nationalId"
                       class="input-field"
                       placeholder="أدخل رقمك القومي المكون من 14 رقم"
                       maxlength="14"
                       inputmode="numeric"
                       autocomplete="off" />
                <span class="input-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <rect x="3" y="4" width="18" height="16" rx="2" />
                        <circle cx="9" cy="10" r="2" />
                        <path d="M15 8h2M15 12h2M7 16h10" />
                    </svg>
                </span>
            </div>

            <div class="row-hint">
                <div class="field-error" id="idError">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="12" />
                        <line x1="12" y1="16" x2="12.01" y2="16" />
                    </svg>
                    يرجى إدخال رقم قومي صحيح مكون من 14 رقم.
                </div>
                <div class="char-counter" id="charCounter">0 / 14</div>
            </div>

            <button class="btn-search" id="searchBtn" type="button" onclick="handleSearch()">
                <div class="spinner"></div>
                <span class="btn-text" style="display:flex;align-items:center;gap:.5rem">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                    استعلام عن نتيجة القبول
                </span>
            </button>
        </div>

        <div id="resultArea"></div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
            crossorigin="anonymous"></script>

    <script>
        const input   = document.getElementById('nationalId');
        const counter = document.getElementById('charCounter');

        input.addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '');
            const len  = this.value.length;
            counter.textContent = `${len} / 14`;
            counter.classList.toggle('done', len === 14);
            if (len === 14) {
                this.classList.remove('invalid');
                document.getElementById('idError').style.display = 'none';
            }
        });

        async function handleSearch() {
            const id  = input.value.trim();
            const err = document.getElementById('idError');

            input.classList.remove('invalid');
            err.style.display = 'none';

            if (!/^\d{14}$/.test(id)) {
                input.classList.add('invalid');
                err.style.display = 'flex';
                input.focus();
                return;
            }

            const btn = document.getElementById('searchBtn');
            btn.classList.add('loading');
            btn.disabled = true;
            document.getElementById('resultArea').innerHTML = '';

            try {
                const res    = await fetch(`/Home/CheckAcceptance?id=${encodeURIComponent(id)}`);
                const record = await res.json();
                renderByStatus(record);
            } catch {
                renderError();
            } finally {
                btn.classList.remove('loading');
                btn.disabled = false;
            }
        }

        function renderByStatus(r) {
            if      (r.status === 'accepted')     renderAccepted(r);
            else if (r.status === 'under_review') renderUnderReview(r);
            else                                  renderNotFound();
        }

        function renderAccepted(r) {
            document.getElementById('resultArea').innerHTML = `
            <div class="result-card">
                <div class="result-header accepted">
                    <div class="result-icon accepted">🎉</div>
                    <div>
                        <div class="result-title accepted">مبروك! تم قبولك في السكن</div>
                        <div class="result-subtitle">${r.name ?? ''}</div>
                    </div>
                    <span class="status-pill accepted">
                        <span class="pulse-dot"></span>مقبول
                    </span>
                </div>
                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-label">الاسم الكامل</div>
                        <div class="info-value">${r.name ?? '—'}</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">الكلية</div>
                        <div class="info-value blue">${r.faculty ?? '—'}</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">الفرقة الدراسية</div>
                        <div class="info-value">${r.grade ?? '—'}</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">نوع الدراسة</div>
                        <div class="info-value">${r.studyType ?? '—'}</div>
                    </div>
                    <div class="info-item" style="grid-column:1/-1">
                        <div class="info-label">كود الطالب</div>
                        <div class="info-value green">${r.seat ?? '—'}</div>
                    </div>
                </div>
            </div>`;
        }

        function renderUnderReview(r) {
            document.getElementById('resultArea').innerHTML = `
            <div class="result-card">
                <div class="result-header under_review">
                    <div class="result-icon under_review">⏳</div>
                    <div>
                        <div class="result-title under_review">طلبك قيد المراجعة</div>
                        <div class="result-subtitle">${r.name ?? ''}</div>
                    </div>
                    <span class="status-pill under_review">
                        <span class="pulse-dot"></span>قيد المراجعة
                    </span>
                </div>
                <div class="review-notice">
                    <div class="review-notice-icon">📋</div>
                    <div class="review-notice-text">
                        <strong>ملاحظة هامة</strong>
                        تم استلام طلبك وهو قيد المراجعة حالياً من قِبَل لجنة القبول.
                        سيتم إشعارك فور صدور القرار النهائي. يُرجى المتابعة بشكل دوري.
                    </div>
                </div>
                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-label">الاسم الكامل</div>
                        <div class="info-value">${r.name ?? '—'}</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">الكلية المتقدم إليها</div>
                        <div class="info-value blue">${r.faculty ?? '—'}</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">الفرقة الدراسية</div>
                        <div class="info-value">${r.grade ?? '—'}</div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">نوع الدراسة</div>
                        <div class="info-value">${r.studyType ?? '—'}</div>
                    </div>
                    <div class="info-item" style="grid-column:1/-1">
                        <div class="info-label">حالة الطلب</div>
                        <div class="info-value amber">في انتظار قرار لجنة القبول</div>
                    </div>
                </div>
            </div>`;
        }

        function renderNotFound() {
            document.getElementById('resultArea').innerHTML = `
            <div class="notfound-card">
                <span class="notfound-icon">🔍</span>
                <h3>لم يتم العثور على نتيجة</h3>
                <p>لا يوجد سجل مرتبط بهذا الرقم القومي.<br>تأكد من صحة الرقم أو تواصل مع إدارة القبول.</p>
            </div>`;
        }

        function renderError() {
            document.getElementById('resultArea').innerHTML = `
            <div class="notfound-card">
                <span class="notfound-icon">⚠️</span>
                <h3>حدث خطأ في الاتصال</h3>
                <p>تعذّر الوصول إلى الخادم. يُرجى التحقق من اتصالك بالإنترنت والمحاولة مرة أخرى.</p>
            </div>`;
        }

        document.addEventListener('keydown', e => { if (e.key === 'Enter') handleSearch(); });
    </script>

</body>
</html>
