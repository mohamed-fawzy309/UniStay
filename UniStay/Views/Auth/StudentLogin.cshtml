@model UniStay.ViewModels.StudentLoginViewModel
@{
    ViewData["Title"] = "تسجيل دخول الطالب";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — UniStay</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <style>
        /* ── Variables ── */
        :root {
            --blue: #3b82f6;
            --blue-light: #60a5fa;
            --blue-dim: rgba(59,130,246,.15);
            --dark: #0b0f1a;
            --dark-card: #111827;
            --dark-input: #1a2236;
            --dark-border: #1f2d45;
            --text-muted: #6b7a99;
            --text-main: #e2e8f5;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: var(--dark);
            color: var(--text-main);
            min-height: 100vh;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ── Animated Background ── */
        .bg-scene {
            position: fixed;
            inset: 0;
            z-index: 0;
            overflow: hidden;
        }

            .bg-scene::before {
                content: '';
                position: absolute;
                inset: 0;
                background-image: linear-gradient(rgba(59,130,246,.04) 1px, transparent 1px), linear-gradient(90deg, rgba(59,130,246,.04) 1px, transparent 1px);
                background-size: 60px 60px;
                animation: gridShift 20s linear infinite;
            }

        @@keyframes gridShift {
            from

        {
            transform: translateY(0);
        }

        to {
            transform: translateY(60px);
        }

        }

        .orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            animation: floatOrb var(--dur) ease-in-out infinite alternate;
        }

        .orb-1 {
            width: 500px;
            height: 500px;
            background: rgba(59,130,246,.07);
            top: -100px;
            right: -100px;
            --dur: 8s;
        }

        .orb-2 {
            width: 400px;
            height: 400px;
            background: rgba(15,40,100,.25);
            bottom: -80px;
            left: -80px;
            --dur: 11s;
        }

        .orb-3 {
            width: 300px;
            height: 300px;
            background: rgba(59,130,246,.05);
            top: 50%;
            left: 10%;
            --dur: 14s;
        }

        @@keyframes floatOrb {
            from

        {
            transform: translate(0,0) scale(1);
        }

        to {
            transform: translate(30px,30px) scale(1.1);
        }

        }

        .geo {
            position: absolute;
            border: 1px solid rgba(59,130,246,.12);
            animation: rotateSpin var(--dur) linear infinite;
        }

        .geo-1 {
            width: 120px;
            height: 120px;
            top: 15%;
            left: 8%;
            --dur: 25s;
        }

        .geo-2 {
            width: 80px;
            height: 80px;
            bottom: 20%;
            right: 12%;
            --dur: 18s;
            animation-direction: reverse;
        }

        .geo-3 {
            width: 60px;
            height: 60px;
            top: 60%;
            left: 5%;
            --dur: 30s;
        }

        @@keyframes rotateSpin {
            from

        {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }

        }

        /* ── Wrapper ── */
        .login-wrapper {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 460px;
            padding: 1.5rem;
            animation: wrapperIn .8s cubic-bezier(.22,1,.36,1) both;
        }

        @@keyframes wrapperIn {
            from

        {
            opacity: 0;
            transform: translateY(40px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        /* ── Card ── */
        .login-card {
            background: var(--dark-card);
            border: 1px solid var(--dark-border);
            border-radius: 20px;
            padding: 2.8rem 2.5rem;
            box-shadow: 0 0 0 1px rgba(59,130,246,.08), 0 40px 80px rgba(0,0,0,.6), inset 0 1px 0 rgba(255,255,255,.04);
            position: relative;
            overflow: hidden;
        }

            .login-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 10%;
                right: 10%;
                height: 2px;
                background: linear-gradient(90deg, transparent, var(--blue), transparent);
                border-radius: 0 0 4px 4px;
            }

        /* ── Brand ── */
        .brand-mark {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: .6rem;
            margin-bottom: 2.2rem;
            animation: fadeUp .6s .15s both;
        }

        .brand-icon {
            width: 68px;
            height: 68px;
            background: linear-gradient(135deg, #1a2236, #0f172a);
            border: 1px solid var(--dark-border);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: var(--blue);
            box-shadow: 0 8px 30px rgba(0,0,0,.4), 0 0 0 1px rgba(59,130,246,.1);
            position: relative;
        }

            .brand-icon::after {
                content: '';
                position: absolute;
                inset: -1px;
                border-radius: 18px;
                background: linear-gradient(135deg, rgba(59,130,246,.2), transparent);
                pointer-events: none;
            }

        .brand-name {
            font-size: 1.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--blue-light), var(--blue));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .brand-sub {
            font-size: .8rem;
            color: var(--text-muted);
            letter-spacing: .12em;
            text-transform: uppercase;
            margin-top: -.4rem;
        }

        /* ── Fields ── */
        .field-group {
            margin-bottom: 1.2rem;
            animation: fadeUp .6s var(--delay) both;
        }

        @@keyframes fadeUp {
            from

        {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .field-label {
            display: block;
            font-size: .82rem;
            font-weight: 500;
            color: var(--text-muted);
            margin-bottom: .5rem;
            letter-spacing: .04em;
        }

        .field-wrap {
            position: relative;
        }

        .field-icon {
            position: absolute;
            top: 50%;
            right: 1rem;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: .9rem;
            pointer-events: none;
            transition: color .25s;
        }

        .form-control {
            background: var(--dark-input) !important;
            border: 1px solid var(--dark-border) !important;
            color: var(--text-main) !important;
            border-radius: 10px !important;
            padding: .75rem 2.8rem .75rem 1rem !important;
            font-family: 'Tajawal', sans-serif !important;
            font-size: .95rem !important;
            transition: border-color .25s, box-shadow .25s !important;
            height: auto !important;
        }

            .form-control::placeholder {
                color: #3d4f6b !important;
            }

            .form-control:focus {
                border-color: var(--blue) !important;
                box-shadow: 0 0 0 3px var(--blue-dim) !important;
                outline: none !important;
            }

                .form-control:focus + .field-icon {
                    color: var(--blue);
                }

        .toggle-pass {
            position: absolute;
            top: 50%;
            left: 1rem;
            transform: translateY(-50%);
            color: var(--text-muted);
            cursor: pointer;
            font-size: .9rem;
            background: none;
            border: none;
            padding: 0;
            line-height: 1;
            transition: color .25s;
        }

            .toggle-pass:hover {
                color: var(--blue);
            }

        /* ── Extras row ── */
        .row-extras {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.6rem;
            animation: fadeUp .6s .5s both;
        }

        .remember-label {
            display: flex;
            align-items: center;
            gap: .45rem;
            cursor: pointer;
            font-size: .85rem;
            color: var(--text-muted);
            user-select: none;
        }

            .remember-label input[type="checkbox"] {
                width: 16px;
                height: 16px;
                accent-color: var(--blue);
                cursor: pointer;
            }

        .forgot-link {
            font-size: .82rem;
            color: var(--blue);
            text-decoration: none;
            opacity: .8;
            transition: opacity .2s;
        }

            .forgot-link:hover {
                opacity: 1;
                color: var(--blue-light);
            }

        /* ── Button ── */
        .btn-login {
            width: 100%;
            padding: .85rem;
            background: linear-gradient(135deg, var(--blue), #1d4ed8);
            border: none;
            border-radius: 10px;
            color: #fff;
            font-family: 'Tajawal', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            letter-spacing: .04em;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            transition: transform .2s, box-shadow .2s;
            animation: fadeUp .6s .6s both;
        }

            .btn-login::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 60%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,.2), transparent);
                transition: left .5s;
            }

            .btn-login:hover::before {
                left: 150%;
            }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 30px rgba(59,130,246,.4);
            }

            .btn-login:active {
                transform: translateY(0);
            }

            .btn-login.loading .btn-text {
                opacity: 0;
            }

            .btn-login.loading .btn-spinner {
                display: flex !important;
            }

        .btn-spinner {
            display: none !important;
            position: absolute;
            inset: 0;
            align-items: center;
            justify-content: center;
        }

        /* ── Register link ── */
        .register-row {
            margin-top: 1.4rem;
            text-align: center;
            font-size: .85rem;
            color: var(--text-muted);
            animation: fadeUp .6s .7s both;
        }

            .register-row a {
                color: var(--blue-light);
                text-decoration: none;
                font-weight: 600;
                transition: color .2s;
            }

                .register-row a:hover {
                    color: #fff;
                }

        /* ── Admin link ── */
        .admin-link-row {
            margin-top: .8rem;
            text-align: center;
            animation: fadeUp .6s .75s both;
        }

        .admin-link {
            font-size: .78rem;
            color: var(--text-muted);
            text-decoration: none;
            transition: color .2s;
            display: inline-flex;
            align-items: center;
            gap: .3rem;
        }

            .admin-link:hover {
                color: var(--blue-light);
            }

        /* ── Alerts ── */
        .alert-box {
            border-radius: 10px;
            padding: .75rem 1rem;
            font-size: .88rem;
            margin-bottom: 1.2rem;
            display: none;
        }

            .alert-box.show {
                display: flex;
                align-items: center;
                gap: .6rem;
            }

        .alert-success {
            background: rgba(34,197,94,.12);
            border: 1px solid rgba(34,197,94,.3);
            color: #4ade80;
            animation: fadeUp .4s both;
        }

        .alert-error {
            background: rgba(220,53,69,.12);
            border: 1px solid rgba(220,53,69,.3);
            color: #f87171;
            animation: shakeIn .4s both;
        }

        @@keyframes shakeIn {
            0%,100%

        {
            transform: translateX(0);
        }

        20%, 60% {
            transform: translateX(-6px);
        }

        40%, 80% {
            transform: translateX(6px);
        }

        }

        /* ── Validation ── */
        .field-error {
            font-size: .78rem;
            color: #f87171;
            margin-top: .3rem;
            display: block;
        }

        .divider {
            display: flex;
            align-items: center;
            gap: .8rem;
            margin: 1.6rem 0 1rem;
            color: var(--text-muted);
            font-size: .78rem;
            animation: fadeUp .6s .7s both;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--dark-border);
            }

        .card-footer-text {
            text-align: center;
            font-size: .78rem;
            color: var(--text-muted);
            margin-top: 1rem;
            animation: fadeUp .6s .8s both;
        }

            .card-footer-text span {
                color: var(--blue);
            }
    </style>
</head>
<body>

    <!-- Background -->
    <div class="bg-scene">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
        <div class="geo geo-1"></div>
        <div class="geo geo-2"></div>
        <div class="geo geo-3"></div>
    </div>

    <div class="login-wrapper">
        <div class="login-card">

            <!-- Brand -->
            <div class="brand-mark">
                <div class="brand-icon">
                    <i class="fa-solid fa-graduation-cap"></i>
                </div>
                <div class="brand-name">UniStay</div>
                <div class="brand-sub">بوابة الطالب</div>
            </div>

            <!-- Alerts -->
            @if (TempData["Success"] != null)
            {
                <div class="alert-box alert-success show">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>@TempData["Success"]</span>
                </div>
            }

            <div class="alert-box alert-error" id="alertError">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span id="alertErrorMsg">الرقم القومي أو كلمة المرور غير صحيحة</span>
            </div>

            @if (TempData["Error"] != null)
            {
                <script>
                    document.addEventListener('DOMContentLoaded', () => showError('@TempData["Error"]'));
                </script>
            }

            <!-- Form -->
            <form id="loginForm" asp-action="StudentLogin" asp-controller="Auth" method="post" novalidate>
                @Html.AntiForgeryToken()

                <!-- National ID -->
                <div class="field-group" style="--delay:.3s">
                    <label class="field-label" for="NationalID">
                        <i class="fa-solid fa-id-card me-1" style="color:var(--blue)"></i>
                        الرقم القومي
                    </label>
                    <div class="field-wrap">
                        <input asp-for="NationalID"
                               id="NationalID"
                               class="form-control"
                               placeholder="أدخل الرقم القومي المكوّن من 14 رقماً"
                               autocomplete="username"
                               maxlength="14" />
                        <i class="fa-solid fa-hashtag field-icon"></i>
                    </div>
                    <span asp-validation-for="NationalID" class="field-error"></span>
                    <span class="field-error" id="nationalIdErr"></span>
                </div>

                <!-- Password -->
                <div class="field-group" style="--delay:.4s">
                    <label class="field-label" for="Password">
                        <i class="fa-solid fa-lock me-1" style="color:var(--blue)"></i>
                        كلمة المرور
                    </label>
                    <div class="field-wrap">
                        <input asp-for="Password"
                               id="Password"
                               class="form-control"
                               placeholder="أدخل كلمة المرور"
                               autocomplete="current-password" />
                        <i class="fa-solid fa-lock field-icon"></i>
                        <button type="button" class="toggle-pass" id="togglePass" title="إظهار / إخفاء">
                            <i class="fa-solid fa-eye" id="toggleIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                    <span class="field-error" id="passwordErr"></span>
                </div>

                <!-- Remember + Forgot -->
                <div class="row-extras">
                    <label class="remember-label">
                        <input asp-for="RememberMe" type="checkbox" />
                        تذكرني
                    </label>
                    <a href="#" class="forgot-link">نسيت كلمة المرور؟</a>
                </div>

                <!-- Submit -->
                <button type="submit" class="btn-login" id="submitBtn">
                    <span class="btn-text">
                        <i class="fa-solid fa-arrow-right-to-bracket me-2"></i>
                        تسجيل الدخول
                    </span>
                    <span class="btn-spinner">
                        <i class="fa-solid fa-spinner fa-spin"></i>
                    </span>
                </button>

                <!-- Register -->
                <div class="register-row">
                    طالب جديد؟
                    <a asp-action="Register" asp-controller="Auth">
                        <i class="fa-solid fa-user-plus me-1"></i>سجّل الآن
                    </a>
                </div>

                <!-- Admin link -->
                <div class="admin-link-row">
                    <a asp-action="AdminLogin" asp-controller="Auth" class="admin-link">
                        <i class="fa-solid fa-user-shield"></i>
                        دخول الإدارة
                    </a>
                </div>

                <div class="divider">نظام إدارة السكن الجامعي</div>

                <div class="card-footer-text">
                    UniStay &copy; @DateTime.Now.Year &nbsp;·&nbsp;
                    <span>جميع الحقوق محفوظة</span>
                </div>

            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const $ = id => document.getElementById(id);

        function showError(msg) {
            $('alertErrorMsg').textContent = msg || 'الرقم القومي أو كلمة المرور غير صحيحة';
            $('alertError').classList.add('show');
        }

        // Password toggle
        $('togglePass').addEventListener('click', () => {
            const inp  = $('Password');
            const icon = $('toggleIcon');
            const show = inp.type === 'password';
            inp.type   = show ? 'text' : 'password';
            icon.className = show ? 'fa-solid fa-eye-slash' : 'fa-solid fa-eye';
        });

        // Clear errors on input
        ['NationalID', 'Password'].forEach(id => {
            $(id).addEventListener('input', () => {
                $('alertError').classList.remove('show');
                $(id).classList.remove('is-invalid');
            });
        });

        // National ID — digits only
        $('NationalID').addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '');
        });

        // Validation
        function validate() {
            let valid = true;
            const nid  = $('NationalID').value.trim();
            const pass = $('Password').value;

            $('nationalIdErr').textContent = '';
            $('passwordErr').textContent   = '';

            if (!nid) {
                $('nationalIdErr').textContent = 'الرقم القومي مطلوب';
                $('NationalID').classList.add('is-invalid');
                valid = false;
            } else if (nid.length !== 14) {
                $('nationalIdErr').textContent = 'يجب أن يكون الرقم القومي 14 رقماً';
                $('NationalID').classList.add('is-invalid');
                valid = false;
            }

            if (!pass) {
                $('passwordErr').textContent = 'كلمة المرور مطلوبة';
                $('Password').classList.add('is-invalid');
                valid = false;
            }

            return valid;
        }

        // Submit
        $('loginForm').addEventListener('submit', function (e) {
            if (!validate()) { e.preventDefault(); return; }
            const btn = $('submitBtn');
            btn.classList.add('loading');
            btn.disabled = true;
        });

        // Focus glow
        document.querySelectorAll('.form-control').forEach(input => {
            input.addEventListener('focus', () => {
                const icon = input.closest('.field-wrap').querySelector('.field-icon');
                if (icon) icon.style.color = 'var(--blue)';
            });
            input.addEventListener('blur', () => {
                const icon = input.closest('.field-wrap').querySelector('.field-icon');
                if (icon) icon.style.color = '';
            });
        });
    </script>
</body>
</html>
