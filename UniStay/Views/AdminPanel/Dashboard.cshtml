@model UniStay.Controllers.DashboardViewModel
@{
    ViewData["Title"] = "لوحة التحكم";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>UniStay — لوحة التحكم</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&family=Tajawal:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        :root {
            --blue: #3b82f6;
            --blue-light: #60a5fa;
            --blue-dim: rgba(59,130,246,.15);
            --dark: #0b0f1a;
            --dark-card: #111827;
            --dark-input: #1a2236;
            --dark-border: #1f2d45;
            --text-muted: #6b7a99;
            --text-main: #e2e8f5;
            --success: #10b981;
            --success-dim: rgba(16,185,129,.15);
            --danger: #ef4444;
            --danger-dim: rgba(239,68,68,.12);
            --warning: #f59e0b;
            --warning-dim: rgba(245,158,11,.12);
            --sidebar-w: 260px;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        html, body {
            height: 100%;
            font-family: 'Cairo',sans-serif;
            background: var(--dark);
            color: var(--text-main);
            direction: rtl;
            overflow-x: hidden
        }

        /* ══ GRID ══ */
        .admin-layout {
            display: flex;
            min-height: 100vh
        }

        /* ══ SIDEBAR ══ */
        .sidebar {
            width: var(--sidebar-w);
            flex-shrink: 0;
            background: var(--dark-card);
            border-left: 1px solid var(--dark-border);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            right: 0;
            bottom: 0;
            z-index: 100;
            transition: transform .3s cubic-bezier(.16,1,.3,1);
        }

        .sidebar-logo {
            padding: 1.5rem 1.4rem 1.2rem;
            border-bottom: 1px solid var(--dark-border);
            display: flex;
            align-items: center;
            gap: .75rem;
        }

        .logo-box {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            background: var(--blue-dim);
            border: 1px solid rgba(59,130,246,.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
        }

        .logo-text {
            font-size: 1.1rem;
            font-weight: 900;
            color: var(--blue-light);
            letter-spacing: 1.5px
        }

        .logo-sub {
            font-size: .68rem;
            color: var(--text-muted);
            font-weight: 400;
            margin-top: -.1rem
        }

        /* nav */
        .sidebar-nav {
            flex: 1;
            padding: 1rem .75rem;
            overflow-y: auto
        }

        .nav-section-label {
            font-size: .65rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--text-muted);
            padding: .6rem .7rem .4rem;
            margin-top: .5rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: .75rem;
            padding: .65rem .9rem;
            border-radius: 10px;
            color: var(--text-muted);
            font-size: .88rem;
            font-weight: 600;
            text-decoration: none;
            margin-bottom: .15rem;
            transition: all .2s;
            cursor: pointer;
            border: none;
            background: none;
            width: 100%;
            text-align: right;
        }

            .nav-item:hover {
                background: var(--blue-dim);
                color: var(--blue-light)
            }

            .nav-item.active {
                background: var(--blue-dim);
                color: var(--blue-light);
                border: 1px solid rgba(59,130,246,.2)
            }

            .nav-item svg {
                flex-shrink: 0;
                opacity: .7
            }

            .nav-item.active svg, .nav-item:hover svg {
                opacity: 1
            }

        .nav-badge {
            margin-right: auto;
            background: var(--danger);
            color: #fff;
            font-size: .65rem;
            font-weight: 700;
            padding: .15rem .5rem;
            border-radius: 20px;
            min-width: 20px;
            text-align: center
        }

        /* sidebar footer */
        .sidebar-footer {
            padding: 1rem .75rem;
            border-top: 1px solid var(--dark-border);
        }

        .admin-profile {
            display: flex;
            align-items: center;
            gap: .75rem;
            padding: .6rem .75rem;
            border-radius: 10px;
            background: var(--dark-input);
        }

        .admin-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg,var(--blue),var(--blue-light));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .85rem;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .admin-name {
            font-size: .82rem;
            font-weight: 700;
            color: var(--text-main)
        }

        .admin-role {
            font-size: .7rem;
            color: var(--text-muted)
        }

        /* ══ MAIN CONTENT ══ */
        .main-content {
            margin-right: var(--sidebar-w);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* top bar */
        .topbar {
            height: 64px;
            background: var(--dark-card);
            border-bottom: 1px solid var(--dark-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .topbar-title {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-main)
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 1rem
        }

        .topbar-btn {
            width: 36px;
            height: 36px;
            border-radius: 9px;
            background: var(--dark-input);
            border: 1px solid var(--dark-border);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            cursor: pointer;
            transition: all .2s;
            position: relative;
        }

            .topbar-btn:hover {
                border-color: var(--blue);
                color: var(--blue-light)
            }

        .notif-dot {
            position: absolute;
            top: 6px;
            right: 6px;
            width: 7px;
            height: 7px;
            background: var(--danger);
            border-radius: 50%;
            border: 1.5px solid var(--dark-card);
        }

        /* page content */
        .page-content {
            padding: 2rem;
            flex: 1
        }

        /* ══ STAT CARDS ══ */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit,minmax(200px,1fr));
            gap: 1.25rem;
            margin-bottom: 2rem
        }

        .stat-card {
            background: var(--dark-card);
            border: 1px solid var(--dark-border);
            border-radius: 16px;
            padding: 1.4rem 1.5rem;
            position: relative;
            overflow: hidden;
            transition: transform .25s,box-shadow .25s;
            animation: fadeUp .5s ease both;
        }

            .stat-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 12px 40px rgba(0,0,0,.35)
            }

            .stat-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: var(--card-accent,var(--blue));
                border-radius: 0;
            }

        .stat-card-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: var(--icon-bg,var(--blue-dim));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            margin-bottom: 1rem;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 900;
            color: var(--text-main);
            line-height: 1
        }

        .stat-label {
            font-size: .8rem;
            color: var(--text-muted);
            margin-top: .35rem;
            font-weight: 500
        }

        .stat-change {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            font-size: .72rem;
            font-weight: 700;
            margin-top: .5rem;
            padding: .2rem .55rem;
            border-radius: 20px;
        }

            .stat-change.up {
                background: var(--success-dim);
                color: var(--success)
            }

            .stat-change.warn {
                background: var(--warning-dim);
                color: var(--warning)
            }

            .stat-change.down {
                background: var(--danger-dim);
                color: var(--danger)
            }

        /* ══ SECTION HEADERS ══ */
        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.25rem
        }

        .section-title {
            font-size: 1rem;
            font-weight: 800;
            color: var(--text-main);
            display: flex;
            align-items: center;
            gap: .6rem
        }

            .section-title::before {
                content: '';
                width: 4px;
                height: 18px;
                background: var(--blue);
                border-radius: 4px
            }

        .btn-sm-action {
            font-size: .78rem;
            font-weight: 700;
            padding: .4rem .9rem;
            border-radius: 8px;
            border: 1px solid var(--dark-border);
            background: var(--dark-input);
            color: var(--text-muted);
            cursor: pointer;
            transition: all .2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            font-family: 'Cairo',sans-serif;
        }

            .btn-sm-action:hover {
                border-color: var(--blue);
                color: var(--blue-light);
                background: var(--blue-dim)
            }

            .btn-sm-action.primary {
                background: var(--blue);
                border-color: var(--blue);
                color: #fff
            }

                .btn-sm-action.primary:hover {
                    background: var(--blue-light)
                }

        /* ══ GRID LAYOUT ══ */
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-bottom: 1.5rem
        }

        .grid-3-1 {
            display: grid;
            grid-template-columns: 1.8fr 1fr;
            gap: 1.5rem;
            margin-bottom: 1.5rem
        }
        @@media(max - width:1100px) {
            .grid-2,.grid-3-1

        {
            grid-template-columns: 1fr
        }

        }

        /* ══ CARD ══ */
        .dash-card {
            background: var(--dark-card);
            border: 1px solid var(--dark-border);
            border-radius: 16px;
            overflow: hidden;
            animation: fadeUp .5s ease both;
        }

        .dash-card-header {
            padding: 1.1rem 1.5rem;
            border-bottom: 1px solid var(--dark-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .dash-card-body {
            padding: 1.5rem
        }

        /* ══ TABLE ══ */
        .dash-table {
            width: 100%;
            border-collapse: collapse;
            font-size: .83rem
        }

            .dash-table th {
                padding: .7rem 1rem;
                text-align: right;
                font-weight: 700;
                color: var(--text-muted);
                font-size: .72rem;
                letter-spacing: .06em;
                text-transform: uppercase;
                border-bottom: 1px solid var(--dark-border);
                background: rgba(255,255,255,.02);
            }

            .dash-table td {
                padding: .8rem 1rem;
                border-bottom: 1px solid rgba(31,45,69,.6);
                color: var(--text-main);
                vertical-align: middle;
            }

            .dash-table tbody tr {
                transition: background .15s
            }

                .dash-table tbody tr:hover {
                    background: rgba(59,130,246,.04)
                }

                .dash-table tbody tr:last-child td {
                    border-bottom: none
                }

        /* badges */
        .badge-pill {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            font-size: .72rem;
            font-weight: 700;
            padding: .25rem .65rem;
            border-radius: 20px;
            font-family: 'Cairo',sans-serif;
        }

        .badge-pending {
            background: var(--warning-dim);
            color: var(--warning);
            border: 1px solid rgba(245,158,11,.25)
        }

        .badge-accepted {
            background: var(--success-dim);
            color: var(--success);
            border: 1px solid rgba(16,185,129,.25)
        }

        .badge-rejected {
            background: var(--danger-dim);
            color: var(--danger);
            border: 1px solid rgba(239,68,68,.25)
        }

        .badge-new {
            background: var(--blue-dim);
            color: var(--blue-light);
            border: 1px solid rgba(59,130,246,.25)
        }

        /* action buttons in table */
        .tbl-btn {
            width: 28px;
            height: 28px;
            border-radius: 7px;
            border: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all .2s;
            font-size: .75rem;
        }

            .tbl-btn.accept {
                background: var(--success-dim);
                color: var(--success)
            }

                .tbl-btn.accept:hover {
                    background: var(--success);
                    color: #fff
                }

            .tbl-btn.reject {
                background: var(--danger-dim);
                color: var(--danger)
            }

                .tbl-btn.reject:hover {
                    background: var(--danger);
                    color: #fff
                }

            .tbl-btn.edit {
                background: var(--blue-dim);
                color: var(--blue-light)
            }

                .tbl-btn.edit:hover {
                    background: var(--blue);
                    color: #fff
                }

            .tbl-btn.del {
                background: rgba(239,68,68,.08);
                color: var(--danger)
            }

                .tbl-btn.del:hover {
                    background: var(--danger);
                    color: #fff
                }

        /* ══ QUICK ACTIONS ══ */
        .quick-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: .9rem
        }

        .quick-btn {
            background: var(--dark-input);
            border: 1px solid var(--dark-border);
            border-radius: 12px;
            padding: 1rem;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: .5rem;
            cursor: pointer;
            transition: all .25s;
            text-decoration: none;
            color: var(--text-main);
            font-family: 'Cairo',sans-serif;
        }

            .quick-btn:hover {
                border-color: var(--blue);
                background: var(--blue-dim);
                transform: translateY(-2px)
            }

        .quick-icon {
            font-size: 1.4rem
        }

        .quick-label {
            font-size: .8rem;
            font-weight: 700;
            color: var(--text-main)
        }

        .quick-desc {
            font-size: .7rem;
            color: var(--text-muted)
        }

        /* ══ DATES TABLE ══ */
        .dates-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: .75rem 0;
            border-bottom: 1px solid rgba(31,45,69,.6);
        }

            .dates-item:last-child {
                border-bottom: none
            }

        .dates-cat {
            font-size: .85rem;
            font-weight: 700;
            color: var(--text-main);
            display: flex;
            align-items: center;
            gap: .5rem
        }

            .dates-cat .dot {
                width: 8px;
                height: 8px;
                border-radius: 50%
            }

        .dates-range {
            font-size: .78rem;
            color: var(--text-muted);
            direction: ltr;
            text-align: left
        }

        /* ══ MODAL ══ */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.7);
            backdrop-filter: blur(4px);
            z-index: 200;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

            .modal-overlay.open {
                display: flex;
                animation: fadeIn .2s ease
            }

        .modal-box {
            background: var(--dark-card);
            border: 1px solid var(--dark-border);
            border-radius: 20px;
            width: 100%;
            max-width: 520px;
            overflow: hidden;
            animation: slideUp .35s cubic-bezier(.16,1,.3,1);
        }

        .modal-header {
            padding: 1.4rem 1.5rem;
            border-bottom: 1px solid var(--dark-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .modal-title {
            font-size: 1rem;
            font-weight: 800;
            color: var(--text-main)
        }

        .modal-close {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            border: 1px solid var(--dark-border);
            background: var(--dark-input);
            color: var(--text-muted);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all .2s;
            font-size: 1.1rem;
        }

            .modal-close:hover {
                border-color: var(--danger);
                color: var(--danger)
            }

        .modal-body {
            padding: 1.5rem
        }

        .modal-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid var(--dark-border);
            display: flex;
            gap: .75rem;
            justify-content: flex-end
        }

        /* form inside modal */
        .f-group {
            margin-bottom: 1rem
        }

        .f-label {
            display: block;
            font-size: .8rem;
            font-weight: 700;
            color: var(--text-muted);
            margin-bottom: .4rem;
            letter-spacing: .04em
        }

        .f-input {
            width: 100%;
            background: var(--dark-input);
            border: 1.5px solid var(--dark-border);
            border-radius: 9px;
            color: var(--text-main);
            font-family: 'Cairo',sans-serif;
            font-size: .9rem;
            padding: .7rem 1rem;
            outline: none;
            transition: border-color .2s,box-shadow .2s;
        }

            .f-input:focus {
                border-color: var(--blue);
                box-shadow: 0 0 0 3px var(--blue-dim)
            }

            .f-input::placeholder {
                color: var(--text-muted);
                opacity: .6
            }

        select.f-input option {
            background: var(--dark-card)
        }

        /* btn */
        .btn-primary {
            background: var(--blue);
            border: none;
            border-radius: 9px;
            color: #fff;
            font-family: 'Cairo',sans-serif;
            font-weight: 700;
            font-size: .9rem;
            padding: .65rem 1.5rem;
            cursor: pointer;
            transition: all .2s;
        }

            .btn-primary:hover {
                background: var(--blue-light);
                transform: translateY(-1px)
            }

        .btn-ghost {
            background: transparent;
            border: 1px solid var(--dark-border);
            border-radius: 9px;
            color: var(--text-muted);
            font-family: 'Cairo',sans-serif;
            font-weight: 600;
            font-size: .88rem;
            padding: .65rem 1.2rem;
            cursor: pointer;
            transition: all .2s;
        }

            .btn-ghost:hover {
                border-color: var(--blue);
                color: var(--blue-light)
            }

        /* ══ TOAST ══ */
        .toast-wrap {
            position: fixed;
            bottom: 1.75rem;
            left: 50%;
            transform: translateX(-50%);
            z-index: 500;
            display: flex;
            flex-direction: column;
            gap: .6rem;
            align-items: center
        }

        .toast {
            display: flex;
            align-items: center;
            gap: .6rem;
            padding: .8rem 1.4rem;
            border-radius: 12px;
            font-size: .85rem;
            font-weight: 700;
            backdrop-filter: blur(10px);
            box-shadow: 0 8px 32px rgba(0,0,0,.4);
            animation: toastIn .4s cubic-bezier(.16,1,.3,1) both;
            pointer-events: none;
            font-family: 'Cairo',sans-serif;
        }

            .toast.success {
                background: var(--success-dim);
                color: var(--success);
                border: 1px solid rgba(16,185,129,.3)
            }

            .toast.error {
                background: var(--danger-dim);
                color: var(--danger);
                border: 1px solid rgba(239,68,68,.3)
            }

        /* ══ ANIMATIONS ══ */
        @@keyframes fadeUp {
            from

        {
            opacity: 0;
            transform: translateY(18px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }

        }
        @@keyframes fadeIn {
            from

        {
            opacity: 0
        }

        to {
            opacity: 1
        }

        }
        @@keyframes slideUp {
            from

        {
            opacity: 0;
            transform: translateY(24px)
        }

        to {
            opacity: 1;
            transform: translateY(0)
        }

        }
        @@keyframes toastIn {
            from

        {
            opacity: 0;
            transform: translateX(-50%) translateY(16px)
        }

        to {
            opacity: 1;
            transform: translateX(-50%) translateY(0)
        }

        }

        .stat-card:nth-child(1) {
            animation-delay: .05s
        }

        .stat-card:nth-child(2) {
            animation-delay: .1s
        }

        .stat-card:nth-child(3) {
            animation-delay: .15s
        }

        .stat-card:nth-child(4) {
            animation-delay: .2s
        }

        .stat-card:nth-child(5) {
            animation-delay: .25s
        }

        /* mobile sidebar toggle */
        .sidebar-toggle {
            display: none;
            width: 36px;
            height: 36px;
            border-radius: 9px;
            background: var(--dark-input);
            border: 1px solid var(--dark-border);
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--text-muted)
        }
        @@media(max - width:900px) {
            .sidebar

        {
            transform: translateX(100%)
        }

        .sidebar.open {
            transform: translateX(0)
        }

        .main-content {
            margin-right: 0
        }

        .sidebar-toggle {
            display: flex
        }

        .stats-grid {
            grid-template-columns: repeat(2,1fr)
        }

        }
        @@media(max - width:576px) {
            .stats-grid

        {
            grid-template-columns: 1fr
        }

        .page-content {
            padding: 1rem
        }

        }
    </style>
</head>
<body>
    <div class="admin-layout">

        <!-- ════════ SIDEBAR ════════ -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-logo">
                <div class="logo-box">🏠</div>
                <div>
                    <div class="logo-text">UniStay</div>
                    <div class="logo-sub">لوحة الإدارة</div>
                </div>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section-label">الرئيسية</div>
                <a class="nav-item active" href="/Admin/Index">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></svg>
                    لوحة التحكم
                </a>

                <div class="nav-section-label">الإدارة</div>
                <a class="nav-item" href="/Admin/Students">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                    الطلاب
                    <span class="nav-badge" id="sidebarPending">@Model.PendingApplications</span>
                </a>
                <a class="nav-item" href="/Admin/Acceptances">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 11 12 14 22 4" /><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" /></svg>
                    القبول
                </a>
                <a class="nav-item" href="/Admin/Dates">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    المواعيد
                </a>

                <div class="nav-section-label">الإعدادات</div>
                <a class="nav-item" href="/Admin/Users">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" /><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" /></svg>
                    المستخدمون
                </a>
                <button class="nav-item" onclick="openModal('addStaffModal')">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="19" y1="8" x2="19" y2="14" /><line x1="22" y1="11" x2="16" y2="11" /></svg>
                    إضافة موظف
                </button>
            </nav>

            <div class="sidebar-footer">
                <div class="admin-profile">
                    <div class="admin-avatar">A</div>
                    <div>
                        <div class="admin-name">@User.Identity?.Name</div>
                        <div class="admin-role">مدير النظام</div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- ════════ MAIN ════════ -->
        <div class="main-content">

            <!-- Top Bar -->
            <header class="topbar">
                <div style="display:flex;align-items:center;gap:1rem">
                    <button class="sidebar-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">
                        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" /></svg>
                    </button>
                    <div>
                        <div class="topbar-title">لوحة التحكم</div>
                        <div style="font-size:.72rem;color:var(--text-muted)">مرحباً، @User.Identity?.Name 👋</div>
                    </div>
                </div>
                <div class="topbar-right">
                    <div class="topbar-btn" title="الإشعارات">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" /><path d="M13.73 21a2 2 0 0 1-3.46 0" /></svg>
                        <span class="notif-dot"></span>
                    </div>
                    <form method="post" asp-controller="Auth" asp-action="Logout" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="topbar-btn">
                            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                        </button>
                    </form>
                </div>
            </header>

            <!-- Page Content -->
            <main class="page-content">

                <!-- TempData toast -->
                @if (TempData["Success"] != null)
                {
                    <div id="autoToast" class="toast success" style="position:fixed;bottom:1.75rem;left:50%;transform:translateX(-50%);z-index:500">
                        ✅ @TempData["Success"]
                    </div>
                    <script>setTimeout(()=>{const t=document.getElementById('autoToast');if(t){t.style.opacity='0';t.style.transition='opacity .4s';setTimeout(()=>t.remove(),400);}},3500)</script>
                }

                <!-- ── STAT CARDS ── -->
                <div class="stats-grid">
                    <div class="stat-card" style="--card-accent:var(--blue);--icon-bg:var(--blue-dim)">
                        <div class="stat-card-icon">🎓</div>
                        <div class="stat-value">@Model.TotalStudents</div>
                        <div class="stat-label">إجمالي الطلاب</div>
                        <span class="stat-change up">↑ مسجلون</span>
                    </div>
                    <div class="stat-card" style="--card-accent:var(--warning);--icon-bg:var(--warning-dim)">
                        <div class="stat-card-icon">⏳</div>
                        <div class="stat-value">@Model.PendingApplications</div>
                        <div class="stat-label">طلبات معلقة</div>
                        <span class="stat-change warn">تحتاج مراجعة</span>
                    </div>
                    <div class="stat-card" style="--card-accent:var(--success);--icon-bg:var(--success-dim)">
                        <div class="stat-card-icon">✅</div>
                        <div class="stat-value">@Model.TotalAccepted</div>
                        <div class="stat-label">مقبولون</div>
                        <span class="stat-change up">↑ قبول</span>
                    </div>
                    <div class="stat-card" style="--card-accent:var(--danger);--icon-bg:var(--danger-dim)">
                        <div class="stat-card-icon">❌</div>
                        <div class="stat-value">@Model.TotalRejected</div>
                        <div class="stat-label">مرفوضون</div>
                        <span class="stat-change down">↓ رفض</span>
                    </div>
                    <div class="stat-card" style="--card-accent:#a78bfa;--icon-bg:rgba(167,139,250,.12)">
                        <div class="stat-card-icon">👤</div>
                        <div class="stat-value">@Model.TotalAdmins</div>
                        <div class="stat-label">المسؤولون</div>
                        <span class="stat-change up">نشطون</span>
                    </div>
                </div>

                <!-- ── CHART + QUICK ACTIONS ── -->
                <div class="grid-3-1">
                    <!-- Chart -->
                    <div class="dash-card">
                        <div class="dash-card-header">
                            <span class="section-title">إحصائيات الطلبات</span>
                            <select class="btn-sm-action" id="chartFilter" onchange="updateChart(this.value)" style="cursor:pointer">
                                <option value="status">حسب الحالة</option>
                                <option value="month">حسب الشهر</option>
                            </select>
                        </div>
                        <div class="dash-card-body">
                            <canvas id="mainChart" height="220"></canvas>
                        </div>
                    </div>

                    <!-- Quick Actions -->
                    <div class="dash-card">
                        <div class="dash-card-header">
                            <span class="section-title">إجراءات سريعة</span>
                        </div>
                        <div class="dash-card-body">
                            <div class="quick-grid">
                                <button class="quick-btn" onclick="openModal('addStaffModal')">
                                    <span class="quick-icon">👤</span>
                                    <span class="quick-label">إضافة موظف</span>
                                    <span class="quick-desc">إضافة مسؤول جديد</span>
                                </button>
                                <a class="quick-btn" href="/Admin/Students">
                                    <span class="quick-icon">📋</span>
                                    <span class="quick-label">الطلاب</span>
                                    <span class="quick-desc">عرض جميع الطلاب</span>
                                </a>
                                <a class="quick-btn" href="/Admin/Dates">
                                    <span class="quick-icon">📅</span>
                                    <span class="quick-label">المواعيد</span>
                                    <span class="quick-desc">إدارة مواعيد القبول</span>
                                </a>
                                <a class="quick-btn" href="/Admin/Acceptances">
                                    <span class="quick-icon">✅</span>
                                    <span class="quick-label">القبول</span>
                                    <span class="quick-desc">مراجعة الطلبات</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── RECENT APPLICATIONS + DATES ── -->
                <div class="grid-3-1">

                    <!-- Recent Applications -->
                    <div class="dash-card">
                        <div class="dash-card-header">
                            <span class="section-title">آخر الطلبات</span>
                            <a href="/Admin/Acceptances" class="btn-sm-action">عرض الكل</a>
                        </div>
                        <div style="overflow-x:auto">
                            <table class="dash-table">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>الاسم</th>
                                        <th>الكلية</th>
                                        <th>النوع</th>
                                        <th>الحالة</th>
                                        <th>إجراء</th>
                                    </tr>
                                </thead>
                                <tbody id="appTableBody">
                                    @if (Model.RecentApplications != null)
                                    {
                                        int i = 1;
                                        foreach (var app in Model.RecentApplications)
                                        {
                                            <tr id="row-@app.StudentId">
                                                <td style="color:var(--text-muted)">@i</td>
                                                <td style="font-weight:700">@app.Student?.FullNameArabic</td>
                                                <td style="color:var(--text-muted)">@app.Student?.Faculty</td>
                                                <td>
                                                    <span class="badge-pill @(app.Student?.StudentStatus == "New" ? "badge-new" : "badge-pending")">
                                                        @(app.Student?.StudentStatus == "New" ? "مستجد" : "قديم")
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="badge-pill @(app.Status == "Accepted" ? "badge-accepted" : app.Status == "Rejected" ? "badge-rejected" : "badge-pending")" id="status-@app.ApplicationId">
                                                        @(app.Status == "Accepted" ? "مقبول" : app.Status == "Rejected" ? "مرفوض" : "معلق")
                                                    </span>
                                                </td>
                                                <td>
                                                    <div style="display:flex;gap:.4rem">
                                                        @if (app.Status != "Accepted")
                                                        {
                                                            <button class="tbl-btn accept" title="قبول" onclick="changeStatus(@app.ApplicationId,'Accepted')">✓</button>
                                                        }
                                                        @if (app.Status != "Rejected")
                                                        {
                                                            <button class="tbl-btn reject" title="رفض" onclick="changeStatus(@app.ApplicationId,'Rejected')">✗</button>
                                                        }
                                                        <a class="tbl-btn edit" href="/Admin/StudentDetails/@app.StudentId" title="تفاصيل">👁</a>
                                                    </div>
                                                </td>
                                            </tr>
                                            i++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Dates -->
                    <div class="dash-card">
                        <div class="dash-card-header">
                            <span class="section-title">مواعيد القبول</span>
                            <a href="/Admin/Dates" class="btn-sm-action">تعديل</a>
                        </div>
                        <div class="dash-card-body" style="padding-top:.75rem">
                            @if (Model.RegistrationDates != null)
                            {
                                foreach (var d in Model.RegistrationDates)
                                {
                                    <div class="dates-item">
                                        <div class="dates-cat">
                                            <span class="dot" style="background:@(d.Category.Contains("جديد") || d.Category.Contains("New") ? "var(--blue)" : d.Category.Contains("بحث") || d.Category.Contains("Research") ? "var(--warning)" : "#e879f9")"></span>
                                            @d.Category
                                        </div>
                                        <div class="dates-range">@d.StartDate.ToString("d/M") – @d.EndDate.ToString("d/M")</div>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                </div>
            </main>
        </div>
    </div>

    <!-- ════════ ADD STAFF MODAL ════════ -->
    <div class="modal-overlay" id="addStaffModal">
        <div class="modal-box">
            <div class="modal-header">
                <div class="modal-title">➕ إضافة موظف جديد</div>
                <button class="modal-close" onclick="closeModal('addStaffModal')">✕</button>
            </div>
            <div class="modal-body">
                <form asp-controller="Admin" asp-action="UserCreate" method="post" id="addStaffForm">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="f-group">
                                <label class="f-label">الاسم الكامل</label>
                                <input name="Name" class="f-input" placeholder="اسم الموظف" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="f-group">
                                <label class="f-label">اسم المستخدم</label>
                                <input name="Username" class="f-input" placeholder="username" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="f-group">
                                <label class="f-label">البريد الإلكتروني</label>
                                <input name="Email" type="email" class="f-input" placeholder="email@unistay.com" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="f-group">
                                <label class="f-label">رقم الهاتف</label>
                                <input name="Phone" class="f-input" placeholder="01XXXXXXXXX" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="f-group">
                                <label class="f-label">الدور الوظيفي</label>
                                <select name="Role" class="f-input">
                                    <option value="Admin">مدير</option>
                                    <option value="Staff">موظف</option>
                                    <option value="Viewer">مشاهد فقط</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="f-group">
                                <label class="f-label">كلمة المرور</label>
                                <input name="Password" type="password" class="f-input" placeholder="••••••••" required />
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button class="btn-ghost" onclick="closeModal('addStaffModal')">إلغاء</button>
                <button class="btn-primary" onclick="document.getElementById('addStaffForm').submit()">✅ إضافة الموظف</button>
            </div>
        </div>
    </div>

    <!-- Toast container -->
    <div class="toast-wrap" id="toastWrap"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        /* ═══ MODAL ═══ */
        function openModal(id)  { document.getElementById(id).classList.add('open');  document.body.style.overflow='hidden'; }
        function closeModal(id) { document.getElementById(id).classList.remove('open'); document.body.style.overflow=''; }
        document.querySelectorAll('.modal-overlay').forEach(m => {
          m.addEventListener('click', e => { if (e.target === m) closeModal(m.id); });
        });

        /* ═══ TOAST ═══ */
        function showToast(msg, type='success') {
          const wrap = document.getElementById('toastWrap');
          const t = document.createElement('div');
          t.className = `toast ${type}`;
          t.textContent = (type === 'success' ? '✅ ' : '❌ ') + msg;
          wrap.appendChild(t);
          setTimeout(() => { t.style.opacity='0'; t.style.transition='opacity .4s'; setTimeout(()=>t.remove(),400); }, 3000);
        }

        /* ═══ ACCEPT / REJECT ═══ */
        async function changeStatus(id, status) {
          try {
            const res = await fetch('/Admin/UpdateAcceptanceStatus', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '' },
              body: JSON.stringify({ id, status })
            });
            if (!res.ok) throw new Error();

            const badge = document.getElementById('status-' + id);
            if (badge) {
              badge.className = 'badge-pill ' + (status === 'Accepted' ? 'badge-accepted' : 'badge-rejected');
              badge.textContent = status === 'Accepted' ? 'مقبول' : 'مرفوض';
            }

            // hide the used button
            const row = document.getElementById('row-' + id);
            if (row) {
              row.querySelectorAll('.tbl-btn').forEach(btn => {
                if ((status === 'Accepted' && btn.classList.contains('accept')) ||
                    (status === 'Rejected' && btn.classList.contains('reject'))) btn.style.display = 'none';
              });
            }

            showToast(status === 'Accepted' ? 'تم قبول الطلب بنجاح' : 'تم رفض الطلب');

            // update pending counter
            const pending = document.getElementById('sidebarPending');
            if (pending) pending.textContent = Math.max(0, parseInt(pending.textContent) - 1);

          } catch { showToast('حدث خطأ، حاول مرة أخرى', 'error'); }
        }

        /* ═══ CHART ═══ */
        const chartData = {
          status: {
            labels: ['معلق', 'مقبول', 'مرفوض'],
            data:   [@Model.PendingApplications, @Model.TotalAccepted, @Model.TotalRejected],
            colors: ['rgba(245,158,11,.8)', 'rgba(16,185,129,.8)', 'rgba(239,68,68,.8)'],
            type:   'doughnut'
          },
          month: {
            labels: ['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر'],
            data:   [12,19,8,24,31,18,22,29,35],
            colors: ['rgba(59,130,246,.7)'],
            type:   'bar'
          }
        };

        let myChart;
        function buildChart(filter) {
          const ctx = document.getElementById('mainChart').getContext('2d');
          if (myChart) myChart.destroy();
          const d = chartData[filter];

          myChart = new Chart(ctx, {
            type: d.type,
            data: {
              labels: d.labels,
              datasets: [{
                data: d.data,
                backgroundColor: d.colors.length > 1 ? d.colors : Array(d.data.length).fill(d.colors[0]),
                borderColor: 'transparent',
                borderRadius: d.type === 'bar' ? 8 : 0,
                borderWidth: d.type === 'doughnut' ? 3 : 0,
                borderColor: d.type === 'doughnut' ? '#111827' : 'transparent',
                hoverOffset: 6
              }]
            },
            options: {
              responsive: true, maintainAspectRatio: false,
              plugins: {
                legend: {
                  labels: { color: '#6b7a99', font: { family: 'Cairo', size: 11 }, padding: 16 }
                }
              },
              scales: d.type === 'bar' ? {
                x: { ticks: { color: '#6b7a99', font: { family: 'Cairo' } }, grid: { color: 'rgba(31,45,69,.6)' } },
                y: { ticks: { color: '#6b7a99', font: { family: 'Cairo' } }, grid: { color: 'rgba(31,45,69,.6)' } }
              } : {}
            }
          });
        }

        function updateChart(val) { buildChart(val); }
        buildChart('status');
    </script>
</body>
</html>
