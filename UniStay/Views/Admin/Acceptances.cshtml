@model UniStay.ViewModels.AcceptancesPageViewModel
@{
    ViewData["Title"] = "إدارة الطلبات";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html> 
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css"
          crossorigin="anonymous" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Tajawal:wght@400;500;700&display=swap"
          rel="stylesheet" />

    <style>
        :root {
            --blue: #3b82f6;
            --blue-light: #60a5fa;
            --blue-dim: rgba(59,130,246,.15);
            --dark: #0b0f1a;
            --dark-card: #111827;
            --dark-input: #1a2236;
            --dark-border: #1f2d45;
            --text-muted: #6b7a99;
            --text-main: #e2e8f5;
            --success: #10b981;
            --success-dim: rgba(16,185,129,.15);
            --danger: #ef4444;
            --danger-dim: rgba(239,68,68,.12);
            --warn: #f59e0b;
            --warn-light: #fbbf24;
            --warn-dim: rgba(245,158,11,.15);
            --radius: 14px;
            --radius-sm: 8px;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: var(--dark);
            color: var(--text-main);
            min-height: 100vh;
            direction: rtl;
        }

        .bg-grid {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            background-image: linear-gradient(var(--dark-border) 1px, transparent 1px), linear-gradient(90deg, var(--dark-border) 1px, transparent 1px);
            background-size: 48px 48px;
            opacity: .25;
        }

        .page-wrap {
            position: relative;
            z-index: 1;
            padding: 2.5rem 1.5rem 5rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* ── Page Header ── */
        .page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 2rem;
            animation: fade-down .55s cubic-bezier(.22,1,.36,1) both;
        }

            .page-header h1 {
                font-family: 'Cairo', sans-serif;
                font-weight: 900;
                font-size: clamp(1.5rem, 3vw, 2.2rem);
                line-height: 1.2;
            }

                .page-header h1 span {
                    color: var(--blue-light);
                }

            .page-header p {
                color: var(--text-muted);
                font-size: .95rem;
                margin-top: .3rem;
            }

        /* ── Stat Cards ── */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1rem;
            margin-bottom: 1.75rem;
            animation: fade-up .5s cubic-bezier(.22,1,.36,1) .05s both;
        }

        @@media (max-width: 768px) {
            .stats-row {
                grid-template-columns: repeat(2,1fr);
            }
        }

        @@media (max-width: 400px) {
            .stats-row {
                grid-template-columns: 1fr;
            }
        }

        .stat-card {
            background: var(--dark-card);
            border: 1px solid var(--dark-border);
            border-radius: var(--radius);
            padding: 1.25rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            cursor: pointer;
            transition: border-color .2s, transform .2s;
            text-decoration: none;
            color: inherit;
        }

            .stat-card:hover {
                border-color: var(--blue);
                transform: translateY(-2px);
                color: inherit;
            }

            .stat-card.active-filter {
                border-color: var(--blue);
                box-shadow: 0 0 0 2px var(--blue-dim);
            }

        .stat-icon {
            width: 46px;
            height: 46px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            flex-shrink: 0;
        }

            .stat-icon.all {
                background: var(--blue-dim);
            }

            .stat-icon.pending {
                background: var(--warn-dim);
            }

            .stat-icon.approved {
                background: var(--success-dim);
            }

            .stat-icon.rejected {
                background: var(--danger-dim);
            }

        .stat-value {
            font-family: 'Cairo', sans-serif;
            font-weight: 900;
            font-size: 1.6rem;
            line-height: 1;
        }

            .stat-value.all {
                color: var(--blue-light);
            }

            .stat-value.pending {
                color: var(--warn-light);
            }

            .stat-value.approved {
                color: var(--success);
            }

            .stat-value.rejected {
                color: var(--danger);
            }

        .stat-label {
            font-size: .8rem;
            color: var(--text-muted);
            margin-top: .2rem;
        }

        /* ── Toolbar ── */
        .toolbar {
            display: flex;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 1.25rem;
            animation: fade-up .5s cubic-bezier(.22,1,.36,1) .1s both;
        }

        .search-wrap {
            position: relative;
            flex: 1;
            min-width: 220px;
        }

        .search-icon {
            position: absolute;
            top: 50%;
            right: .9rem;
            transform: translateY(-50%);
            color: var(--text-muted);
            pointer-events: none;
        }

        .search-input {
            width: 100%;
            background: var(--dark-input);
            border: 1.5px solid var(--dark-border);
            border-radius: var(--radius-sm);
            color: var(--text-main);
            font-family: 'Tajawal', sans-serif;
            font-size: .95rem;
            padding: .7rem 2.5rem .7rem 1rem;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
            direction: rtl;
        }

            .search-input::placeholder {
                color: var(--text-muted);
            }

            .search-input:focus {
                border-color: var(--blue);
                box-shadow: 0 0 0 3px var(--blue-dim);
            }

        .btn-search-go {
            background: var(--blue);
            border: none;
            border-radius: var(--radius-sm);
            color: #fff;
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .9rem;
            padding: .7rem 1.4rem;
            cursor: pointer;
            transition: background .2s, transform .15s;
            white-space: nowrap;
        }

            .btn-search-go:hover {
                background: var(--blue-light);
                transform: translateY(-1px);
            }

        /* ── Table Card ── */
        .table-card {
            background: var(--dark-card);
            border: 1px solid var(--dark-border);
            border-radius: var(--radius);
            overflow: hidden;
            animation: fade-up .55s cubic-bezier(.22,1,.36,1) .15s both;
        }

        .table-header-bar {
            padding: 1.1rem 1.5rem;
            border-bottom: 1px solid var(--dark-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: .5rem;
        }

        .table-title {
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: 1rem;
        }

        .result-count {
            font-size: .82rem;
            color: var(--text-muted);
            background: var(--dark-input);
            border: 1px solid var(--dark-border);
            padding: .25rem .7rem;
            border-radius: 20px;
        }

        .table-responsive-wrap {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 860px;
        }

        thead th {
            background: var(--dark-input);
            border-bottom: 1px solid var(--dark-border);
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .78rem;
            letter-spacing: .06em;
            color: var(--text-muted);
            text-transform: uppercase;
            padding: .8rem 1rem;
            white-space: nowrap;
            text-align: right;
        }

        tbody tr {
            border-bottom: 1px solid rgba(31,45,69,.6);
            transition: background .15s;
        }

            tbody tr:last-child {
                border-bottom: none;
            }

            tbody tr:hover {
                background: rgba(59,130,246,.04);
            }

        td {
            padding: 1rem;
            font-size: .9rem;
            vertical-align: middle;
            text-align: right;
        }

        .td-name {
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .95rem;
        }

        .td-sub {
            font-size: .78rem;
            color: var(--text-muted);
            margin-top: .15rem;
        }

        .national-id {
            font-family: monospace;
            font-size: .88rem;
            color: var(--blue-light);
            letter-spacing: .04em;
            direction: ltr;
            display: inline-block;
        }

        /* Status pill */
        .s-pill {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .75rem;
            padding: .25rem .7rem;
            border-radius: 20px;
            white-space: nowrap;
        }

            .s-pill.Pending {
                background: var(--warn-dim);
                color: var(--warn-light);
                border: 1px solid rgba(245,158,11,.35);
            }

            .s-pill.Approved {
                background: var(--success-dim);
                color: var(--success);
                border: 1px solid rgba(16,185,129,.3);
            }

            .s-pill.Rejected {
                background: var(--danger-dim);
                color: var(--danger);
                border: 1px solid rgba(239,68,68,.3);
            }

        .dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
            flex-shrink: 0;
        }

        /* Action buttons */
        .btn-approve, .btn-reject, .btn-details {
            border: none;
            border-radius: var(--radius-sm);
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .78rem;
            padding: .4rem .85rem;
            cursor: pointer;
            transition: opacity .2s, transform .15s;
            display: inline-flex;
            align-items: center;
            gap: .35rem;
        }

        .btn-approve {
            background: var(--success-dim);
            color: var(--success);
            border: 1px solid rgba(16,185,129,.3);
        }

        .btn-reject {
            background: var(--danger-dim);
            color: var(--danger);
            border: 1px solid rgba(239,68,68,.3);
        }

        .btn-details {
            background: var(--blue-dim);
            color: var(--blue-light);
            border: 1px solid rgba(59,130,246,.3);
        }

        .btn-approve:hover {
            opacity: .85;
            transform: translateY(-1px);
        }

        .btn-reject:hover {
            opacity: .85;
            transform: translateY(-1px);
        }

        .btn-details:hover {
            opacity: .85;
            transform: translateY(-1px);
        }

        .actions-cell {
            display: flex;
            gap: .4rem;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        /* Empty state */
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            color: var(--text-muted);
        }

            .empty-state .empty-icon {
                font-size: 3rem;
                display: block;
                margin-bottom: 1rem;
            }

            .empty-state h3 {
                font-family: 'Cairo', sans-serif;
                font-weight: 800;
                font-size: 1.1rem;
                color: var(--text-main);
                margin-bottom: .4rem;
            }

        /* ══ MODALS ══ */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.7);
            backdrop-filter: blur(4px);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

            .modal-overlay.open {
                display: flex;
            }

        .modal-box {
            background: var(--dark-card);
            border: 1px solid var(--dark-border);
            border-radius: var(--radius);
            width: 100%;
            max-width: 640px;
            max-height: 90vh;
            overflow-y: auto;
            animation: pop-in .3s cubic-bezier(.22,1,.36,1) both;
        }

        @@keyframes pop-in {
            from {
                opacity: 0;
                transform: scale(.94) translateY(16px);
            }

            to {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }

        .modal-head {
            padding: 1.3rem 1.5rem;
            border-bottom: 1px solid var(--dark-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            background: var(--dark-card);
            z-index: 1;
        }

            .modal-head h2 {
                font-family: 'Cairo', sans-serif;
                font-weight: 900;
                font-size: 1.05rem;
            }

        .modal-close {
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            font-size: 1.4rem;
            line-height: 1;
            transition: color .2s;
        }

            .modal-close:hover {
                color: var(--text-main);
            }

        .modal-body {
            padding: 1.5rem;
        }

        .detail-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: .85rem;
        }

        @@media (max-width: 500px) {
            .detail-grid {
                grid-template-columns: 1fr;
            }
        }

        .detail-item {
            background: var(--dark-input);
            border: 1px solid var(--dark-border);
            border-radius: var(--radius-sm);
            padding: .75rem 1rem;
        }

        .detail-label {
            font-size: .72rem;
            color: var(--text-muted);
            font-weight: 600;
            letter-spacing: .06em;
            margin-bottom: .2rem;
        }

        .detail-value {
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .93rem;
        }

            .detail-value.blue {
                color: var(--blue-light);
            }

            .detail-value.green {
                color: var(--success);
            }

            .detail-value.amber {
                color: var(--warn-light);
            }

        .section-sep {
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .78rem;
            color: var(--text-muted);
            letter-spacing: .08em;
            text-transform: uppercase;
            padding: .5rem 0 .3rem;
            border-bottom: 1px solid var(--dark-border);
            margin: 1rem 0 .75rem;
            grid-column: 1 / -1;
        }

        /* Confirm modal */
        .confirm-box {
            background: var(--dark-card);
            border: 1px solid var(--dark-border);
            border-radius: var(--radius);
            width: 100%;
            max-width: 460px;
            animation: pop-in .3s cubic-bezier(.22,1,.36,1) both;
        }

        .confirm-icon {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            margin: 0 auto 1rem;
        }

            .confirm-icon.approve {
                background: var(--success-dim);
            }

            .confirm-icon.reject {
                background: var(--danger-dim);
            }

        .confirm-body {
            padding: 2rem 1.75rem;
            text-align: center;
        }

            .confirm-body h3 {
                font-family: 'Cairo', sans-serif;
                font-weight: 900;
                font-size: 1.15rem;
                margin-bottom: .5rem;
            }

            .confirm-body p {
                color: var(--text-muted);
                font-size: .9rem;
                line-height: 1.7;
            }

        .remarks-input {
            width: 100%;
            background: var(--dark-input);
            border: 1.5px solid var(--dark-border);
            border-radius: var(--radius-sm);
            color: var(--text-main);
            font-family: 'Tajawal', sans-serif;
            font-size: .9rem;
            padding: .75rem 1rem;
            outline: none;
            resize: vertical;
            min-height: 80px;
            margin-top: 1rem;
            text-align: right;
            transition: border-color .2s, box-shadow .2s;
        }

            .remarks-input::placeholder {
                color: var(--text-muted);
            }

            .remarks-input:focus {
                border-color: var(--blue);
                box-shadow: 0 0 0 3px var(--blue-dim);
            }

        .confirm-actions {
            display: flex;
            gap: .75rem;
            justify-content: center;
            padding: 0 1.75rem 1.75rem;
        }

        .btn-confirm-approve {
            background: var(--success);
            border: none;
            border-radius: var(--radius-sm);
            color: #fff;
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .95rem;
            padding: .7rem 1.75rem;
            cursor: pointer;
            transition: opacity .2s;
        }

            .btn-confirm-approve:hover {
                opacity: .88;
            }

        .btn-confirm-reject {
            background: var(--danger);
            border: none;
            border-radius: var(--radius-sm);
            color: #fff;
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .95rem;
            padding: .7rem 1.75rem;
            cursor: pointer;
            transition: opacity .2s;
        }

            .btn-confirm-reject:hover {
                opacity: .88;
            }

        .btn-cancel {
            background: var(--dark-input);
            border: 1px solid var(--dark-border);
            border-radius: var(--radius-sm);
            color: var(--text-muted);
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .95rem;
            padding: .7rem 1.5rem;
            cursor: pointer;
            transition: border-color .2s, color .2s;
        }

            .btn-cancel:hover {
                border-color: var(--text-muted);
                color: var(--text-main);
            }

        /* Animations */
        @@keyframes fade-down {
            from {
                opacity: 0;
                transform: translateY(-16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fade-up {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <div class="bg-grid" aria-hidden="true"></div>

    <div class="page-wrap">

        <!-- Page Header -->
        <div class="page-header">
            <div>
                <h1>إدارة <span>طلبات القبول</span></h1>
                <p>استعراض جميع الطلاب المتقدمين واتخاذ قرارات القبول</p>
            </div>
        </div>

        <!-- Stat Cards -->
        <div class="stats-row">
            <a href="@Url.Action("Acceptances","Admin", new{ search = Model.SearchTerm })"
               class="stat-card @(string.IsNullOrEmpty(Model.CurrentFilter) ? "active-filter" : "")">
                <div class="stat-icon all">📋</div>
                <div>
                    <div class="stat-value all">@Model.TotalCount</div>
                    <div class="stat-label">إجمالي الطلبات</div>
                </div>
            </a>
            <a href="@Url.Action("Acceptances","Admin", new{ filter = "Pending", search = Model.SearchTerm })"
               class="stat-card @(Model.CurrentFilter == "Pending" ? "active-filter" : "")">
                <div class="stat-icon pending">⏳</div>
                <div>
                    <div class="stat-value pending">@Model.PendingCount</div>
                    <div class="stat-label">قيد المراجعة</div>
                </div>
            </a>
            <a href="@Url.Action("Acceptances","Admin", new{ filter = "Approved", search = Model.SearchTerm })"
               class="stat-card @(Model.CurrentFilter == "Approved" ? "active-filter" : "")">
                <div class="stat-icon approved">✅</div>
                <div>
                    <div class="stat-value approved">@Model.ApprovedCount</div>
                    <div class="stat-label">مقبول</div>
                </div>
            </a>
            <a href="@Url.Action("Acceptances","Admin", new{ filter = "Rejected", search = Model.SearchTerm })"
               class="stat-card @(Model.CurrentFilter == "Rejected" ? "active-filter" : "")">
                <div class="stat-icon rejected">❌</div>
                <div>
                    <div class="stat-value rejected">@Model.RejectedCount</div>
                    <div class="stat-label">مرفوض</div>
                </div>
            </a>
        </div>

        <!-- Search Toolbar -->
        <form method="get" action="@Url.Action("Acceptances","Admin")">
            <input type="hidden" name="filter" value="@Model.CurrentFilter" />
            <div class="toolbar">
                <div class="search-wrap">
                    <span class="search-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none"
                             viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8" />
                            <line x1="21" y1="21" x2="16.65" y2="16.65" />
                        </svg>
                    </span>
                    <input type="text" name="search" class="search-input"
                           placeholder="ابحث بالاسم أو الرقم القومي..."
                           value="@Model.SearchTerm" />
                </div>
                <button type="submit" class="btn-search-go">بحث</button>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <a href="@Url.Action("Acceptances","Admin", new{ filter = Model.CurrentFilter })"
                       class="btn-cancel" style="padding:.7rem 1rem; font-size:.85rem; text-decoration:none;">
                        مسح
                    </a>
                }
            </div>
        </form>

        <!-- Table -->
        <div class="table-card">
            <div class="table-header-bar">
                <span class="table-title">
                    @(string.IsNullOrEmpty(Model.CurrentFilter) ? "جميع الطلبات" :
                        Model.CurrentFilter == "Pending" ? "الطلبات قيد المراجعة" :
                        Model.CurrentFilter == "Approved" ? "الطلبات المقبولة" : "الطلبات المرفوضة")
                </span>
                <span class="result-count">@Model.Students.Count نتيجة</span>
            </div>

            <div class="table-responsive-wrap">
                @if (Model.Students.Count == 0)
                {
                    <div class="empty-state">
                        <span class="empty-icon">🔍</span>
                        <h3>لا توجد نتائج</h3>
                        <p>لم يتم العثور على طلاب مطابقين للفلتر الحالي.</p>
                    </div>
                }
                else
                {
                    <table>
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>الطالب</th>
                                <th>الرقم القومي</th>
                                <th>الكلية</th>
                                <th>الحالة</th>
                                <th>الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int rowNum = 0;
                            }
                            @foreach (var s in Model.Students)
                            {
                                rowNum++;
                                <tr>
                                    <td style="color:var(--text-muted); font-size:.8rem;">@rowNum</td>

                                    <td>
                                        <div class="td-name">@(s.Name ?? "—")</div>
                                        <div class="td-sub">@(s.Email ?? s.Mobile ?? "—")</div>
                                    </td>

                                    <td>
                                        <span class="national-id">@(s.NationalId ?? "—")</span>
                                    </td>

                                    <td>
                                        <div style="font-size:.88rem;">@(s.Faculty ?? "—")</div>
                                    </td>

                                    <td>
                                        <span class="s-pill @s.Status">
                                            <span class="dot"></span>
                                            @(s.Status == StudentStatus.Pending ? "قيد المراجعة" :
                                                s.Status == StudentStatus.Approved ? "مقبول" : "مرفوض")
                                        </span>
                                    </td>

                                    <td>
                                        <div class="actions-cell">
                                            <!-- Details -->
                                            <button class="btn-details"
                                                    onclick="openDetails(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(s)))">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none"
                                                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                    <circle cx="12" cy="12" r="10" />
                                                    <line x1="12" y1="8" x2="12" y2="12" />
                                                    <line x1="12" y1="16" x2="12.01" y2="16" />
                                                </svg>
                                                تفاصيل
                                            </button>

                                            @if (s.Status != StudentStatus.Approved)
                                            {
                                                <button class="btn-approve"
                                                        onclick="openConfirm('approve', @s.StudentId, '@Html.Raw((s.Name ?? "").Replace("'","\\\""))')">
                                                    ✓ قبول
                                                </button>
                                            }
                                            @if (s.Status != StudentStatus.Rejected)
                                            {
                                                <button class="btn-reject"
                                                        onclick="openConfirm('reject', @s.StudentId, '@Html.Raw((s.Name ?? "").Replace("'","\\\""))')">
                                                    ✕ رفض
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

    </div><!-- /page-wrap -->
    <!-- ══════════════════════════════════
         DETAILS MODAL
    ══════════════════════════════════ -->
    <div class="modal-overlay" id="detailsModal" onclick="closeOnBackdrop(event,'detailsModal')">
        <div class="modal-box" onclick="event.stopPropagation()">
            <div class="modal-head">
                <h2>📋 تفاصيل الطالب</h2>
                <button class="modal-close" onclick="closeModal('detailsModal')">×</button>
            </div>
            <div class="modal-body">
                <div class="detail-grid" id="detailGrid"></div>
            </div>
        </div>
    </div>


    <!-- ══════════════════════════════════
         APPROVE / REJECT CONFIRM MODAL
    ══════════════════════════════════ -->
    <div class="modal-overlay" id="confirmModal" onclick="closeOnBackdrop(event,'confirmModal')">
        <div class="confirm-box" onclick="event.stopPropagation()">
            <div class="confirm-body">
                <div class="confirm-icon" id="confirmIcon"></div>
                <h3 id="confirmTitle"></h3>
                <p id="confirmText"></p>
                <textarea class="remarks-input" id="remarksInput"
                          placeholder="ملاحظات اختيارية (تظهر للمشرف)..."></textarea>
            </div>
            <div class="confirm-actions">
                <button id="confirmBtn" onclick="submitAction()"></button>
                <button class="btn-cancel" onclick="closeModal('confirmModal')">إلغاء</button>
            </div>
        </div>
    </div>

    <!-- hidden forms for POST actions -->
    <form id="approveForm" method="post" action="/Admin/Approve" style="display:none">
        @Html.AntiForgeryToken()
        <input type="hidden" name="studentId" id="af-studentId" />
        <input type="hidden" name="remarks" id="af-remarks" />
        <input type="hidden" name="returnFilter" value="@Model.CurrentFilter" />
        <input type="hidden" name="returnSearch" value="@Model.SearchTerm" />
    </form>

    <form id="rejectForm" method="post" action="/Admin/Reject" style="display:none">
        @Html.AntiForgeryToken()
        <input type="hidden" name="studentId" id="rf-studentId" />
        <input type="hidden" name="remarks" id="rf-remarks" />
        <input type="hidden" name="returnFilter" value="@Model.CurrentFilter" />
        <input type="hidden" name="returnSearch" value="@Model.SearchTerm" />
    </form>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
            crossorigin="anonymous"></script>
    <script>
        /* ── modal helpers ── */
        function closeModal(id) {
            document.getElementById(id).classList.remove('open');
        }
        function closeOnBackdrop(e, id) {
            if (e.target === document.getElementById(id)) closeModal(id);
        }

        /* ── Details modal ── */
        function openDetails(s) {
            const grid = document.getElementById('detailGrid');

            const fmt = v => v ?? '—';
            const bool = v => v === true ? 'نعم' : v === false ? 'لا' : '—';
            const date = v => v ? new Date(v).toLocaleDateString('ar-EG') : '—';

            const statusLabel = s.status === 0 ? 'قيد المراجعة'
                              : s.status === 1 ? 'مقبول' : 'مرفوض';
            const statusClass = s.status === 0 ? 'amber'
                              : s.status === 1 ? 'green' : '';

            grid.innerHTML = `
                <div class="section-sep">البيانات الشخصية</div>
                <div class="detail-item"><div class="detail-label">الاسم الكامل</div><div class="detail-value">${fmt(s.name)}</div></div>
                <div class="detail-item"><div class="detail-label">الرقم القومي</div><div class="detail-value blue" style="direction:ltr;text-align:right">${fmt(s.nationalId)}</div></div>
                <div class="detail-item"><div class="detail-label">الجنس</div><div class="detail-value">${fmt(s.gender)}</div></div>
                <div class="detail-item"><div class="detail-label">تاريخ الميلاد</div><div class="detail-value">${date(s.birthDate)}</div></div>
                <div class="detail-item"><div class="detail-label">الجنسية</div><div class="detail-value">${fmt(s.nationality)}</div></div>
                <div class="detail-item"><div class="detail-label">الديانة</div><div class="detail-value">${fmt(s.religion)}</div></div>

                <div class="section-sep">بيانات الدراسة</div>
                <div class="detail-item"><div class="detail-label">الكلية</div><div class="detail-value">${fmt(s.faculty)}</div></div>
                <div class="detail-item"><div class="detail-label">الفرقة</div><div class="detail-value">${fmt(s.grade)}</div></div>
                <div class="detail-item"><div class="detail-label">نوع الدراسة</div><div class="detail-value">${fmt(s.studyType)}</div></div>
                <div class="detail-item"><div class="detail-label">كود الطالب</div><div class="detail-value blue">${fmt(s.studentCode)}</div></div>

                <div class="section-sep">بيانات التواصل</div>
                <div class="detail-item"><div class="detail-label">البريد الإلكتروني</div><div class="detail-value">${fmt(s.email)}</div></div>
                <div class="detail-item"><div class="detail-label">الجوال</div><div class="detail-value">${fmt(s.mobile)}</div></div>
                <div class="detail-item"><div class="detail-label">اسم الأب</div><div class="detail-value">${fmt(s.fatherName)}</div></div>
                <div class="detail-item"><div class="detail-label">هاتف الأب</div><div class="detail-value">${fmt(s.fatherPhone)}</div></div>

                <div class="section-sep">بيانات الطلب</div>
                <div class="detail-item"><div class="detail-label">تاريخ الطلب</div><div class="detail-value">${date(s.applicationDate)}</div></div>
                <div class="detail-item"><div class="detail-label">العام الدراسي</div><div class="detail-value">${fmt(s.academicYear)}</div></div>
                <div class="detail-item"><div class="detail-label">الفصل الدراسي</div><div class="detail-value">${fmt(s.semester)}</div></div>
                <div class="detail-item"><div class="detail-label">نوع السكن المطلوب</div><div class="detail-value">${fmt(s.housingPreference)}</div></div>
                <div class="detail-item"><div class="detail-label">نظام الوجبات</div><div class="detail-value">${fmt(s.mealPlanType)}</div></div>
                <div class="detail-item"><div class="detail-label">ذوي احتياجات خاصة</div><div class="detail-value">${bool(s.specialNeeds)}</div></div>
                <div class="detail-item"><div class="detail-label">الأسرة في الخارج</div><div class="detail-value">${bool(s.familyAbroad)}</div></div>
                <div class="detail-item" style="grid-column:1/-1">
                    <div class="detail-label">حالة الطلب</div>
                    <div class="detail-value ${statusClass}">${statusLabel}</div>
                </div>
                ${s.adminRemarks ? `
                <div class="detail-item" style="grid-column:1/-1">
                    <div class="detail-label">ملاحظات المشرف</div>
                    <div class="detail-value">${s.adminRemarks}</div>
                </div>` : ''}
            `;

            document.getElementById('detailsModal').classList.add('open');
        }

        /* ── Confirm modal ── */
        let _action = '', _studentId = 0;

        function openConfirm(action, studentId, name) {
            _action    = action;
            _studentId = studentId;

            const icon  = document.getElementById('confirmIcon');
            const title = document.getElementById('confirmTitle');
            const text  = document.getElementById('confirmText');
            const btn   = document.getElementById('confirmBtn');

            document.getElementById('remarksInput').value = '';

            if (action === 'approve') {
                icon.className  = 'confirm-icon approve';
                icon.textContent = '✓';
                title.textContent = 'تأكيد القبول';
                text.textContent  = `هل أنت متأكد من قبول الطالب "${name}"؟ سيتم إشعاره بنتيجة القبول.`;
                btn.className     = 'btn-confirm-approve';
                btn.textContent   = 'نعم، قبول';
            } else {
                icon.className  = 'confirm-icon reject';
                icon.textContent = '✕';
                title.textContent = 'تأكيد الرفض';
                text.textContent  = `هل أنت متأكد من رفض طلب الطالب "${name}"؟`;
                btn.className     = 'btn-confirm-reject';
                btn.textContent   = 'نعم، رفض';
            }

            document.getElementById('confirmModal').classList.add('open');
        }

        function submitAction() {
            const remarks = document.getElementById('remarksInput').value;

            if (_action === 'approve') {
                document.getElementById('af-studentId').value = _studentId;
                document.getElementById('af-remarks').value   = remarks;
                document.getElementById('approveForm').submit();
            } else {
                document.getElementById('rf-studentId').value = _studentId;
                document.getElementById('rf-remarks').value   = remarks;
                document.getElementById('rejectForm').submit();
            }
        }
    </script>

</body>
</html>
