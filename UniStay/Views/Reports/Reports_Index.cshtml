@model UniStay.Controllers.ReportsViewModel
@{
    ViewData["Title"] = "التقارير والإحصائيات";
    Layout = "_AdminLayout";
}

<!-- Stat Row -->
<div class="row g-3 mb-4">
    @{
        var stats = new[] {
    ("إجمالي الطلاب", Model.TotalStudents,       "#0d6efd", "fa-users"),
    ("طلاب نشطون",    Model.ActiveStudents,       "#198754", "fa-user-check"),
    ("طلبات مقبولة",  Model.ApprovedApplications, "#20c997", "fa-check-circle"),
    ("طلبات مرفوضة", Model.RejectedApplications, "#dc3545", "fa-times-circle"),
    ("إجمالي الغرف",  Model.TotalRooms,           "#6610f2", "fa-door-open"),
    ("غرف مشغولة",   Model.OccupiedRooms,        "#fd7e14", "fa-bed"),
    ("مخالفات",       Model.TotalViolations,      "#d63384", "fa-exclamation-triangle"),
    ("صيانة معلقة",   Model.PendingMaintenance,   "#6c757d", "fa-tools"),
    };
    }
    @foreach (var (label, val, color, icon) in stats)
    {
        <div class="col-6 col-md-3">
            <div class="stat-card" style="border-right-color:@color">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <i class="fas @icon" style="color:@color"></i>
                    <span class="text-muted small">@label</span>
                </div>
                <div class="number" style="font-size:1.6rem">@val</div>
            </div>
        </div>
    }
</div>

<!-- Charts Row -->
<div class="row g-3 mb-4">
    <!-- توزيع بالكلية -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">📚 توزيع الطلاب بالكلية</div>
            <div class="card-body">
                <canvas id="facultyChart" height="220"></canvas>
            </div>
        </div>
    </div>

    <!-- الطلبات بالشهر -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">📈 الطلبات آخر 6 شهور</div>
            <div class="card-body">
                <canvas id="monthChart" height="220"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- إشغال المباني -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between">
        🏢 إشغال المباني
        <a href="/Reports/ExportRooms" class="btn btn-sm btn-outline-success">
            <i class="fas fa-download"></i> تصدير
        </a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>المبنى</th>
                    <th>النوع</th>
                    <th>عدد الغرف</th>
                    <th>إجمالي الأسرة</th>
                    <th>المشغول</th>
                    <th>نسبة الإشغال</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model.BuildingOccupancy)
                {
                    <tr>
                        <td><strong>@b.BuildingName</strong></td>
                        <td><span class="badge bg-secondary">@b.BuildingType</span></td>
                        <td>@b.TotalRooms</td>
                        <td>@b.TotalBeds</td>
                        <td>@b.OccupiedBeds</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="progress flex-grow-1" style="height:8px">
                                    <div class="progress-bar @(b.OccupancyPct > 90 ? "bg-danger" : b.OccupancyPct > 70 ? "bg-warning" : "bg-success")"
                                         style="width:@b.OccupancyPct%"></div>
                                </div>
                                <small>@b.OccupancyPct%</small>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- تصدير -->
<div class="card">
    <div class="card-header">⬇️ تصدير التقارير</div>
    <div class="card-body d-flex gap-3 flex-wrap">
        <a href="/Reports/ExportStudents" class="btn btn-outline-primary">
            <i class="fas fa-users me-1"></i> تقرير الطلاب (CSV)
        </a>
        <a href="/Reports/ExportRooms" class="btn btn-outline-success">
            <i class="fas fa-door-open me-1"></i> تقرير الغرف (CSV)
        </a>
    </div>
</div>

@section Scripts {
    <script>
        // Faculty Chart
        new Chart(document.getElementById('facultyChart'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StudentsByFaculty.Select(x => x.Label))),
                datasets: [{
                    label: 'عدد الطلاب',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StudentsByFaculty.Select(x => x.Value))),
                    backgroundColor: '#0d6efd88',
                    borderColor: '#0d6efd',
                    borderWidth: 2,
                    borderRadius: 6,
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true } }
            }
        });

        // Monthly Chart
        new Chart(document.getElementById('monthChart'), {
            type: 'line',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ApplicationsByMonth.Select(x => x.Label))),
                datasets: [{
                    label: 'الطلبات',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ApplicationsByMonth.Select(x => x.Value))),
                    borderColor: '#198754',
                    backgroundColor: '#19875420',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 5,
                }]
            },
            options: { responsive: true, scales: { y: { beginAtZero: true } } }
        });
    </script>
}
