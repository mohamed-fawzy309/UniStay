@{
    ViewData["Title"] = "مواعيد التسجيل";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap RTL -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css"
          integrity="sha384-nU14brUcp6StFntEOOEBvcJm4huWjB0OcIeQ3fltAfSmuZFrkAif0T+UtNGlKKQv"
          crossorigin="anonymous" />

    <!-- Google Fonts – Arabic-friendly pair -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Tajawal:wght@400;500;700&display=swap"
          rel="stylesheet" />

    <style>
        /* ── Tokens ── */
        :root {
            --brand-dark: #0d1b2a;
            --brand-mid: #1b3a5c;
            --brand-accent: #2e86de;
            --brand-gold: #f0a500;
            --brand-light: #e8f1fb;
            --text-main: #1a2535;
            --text-muted: #5a7289;
            --radius: 14px;
            --shadow: 0 8px 32px rgba(13,27,42,.12);
        }

        /* ── Base ── */
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: #f4f8fd;
            color: var(--text-main);
            min-height: 100vh;
            direction: rtl;
        }

        /* ── Hero banner ── */
        .dates-hero {
            background: linear-gradient(135deg, var(--brand-dark) 0%, var(--brand-mid) 60%, var(--brand-accent) 100%);
            padding: 3.5rem 1.5rem 4.5rem;
            position: relative;
            overflow: hidden;
        }

            .dates-hero::before {
                content: '';
                position: absolute;
                inset: 0;
                background: radial-gradient(circle at 20% 50%, rgba(46,134,222,.25) 0%, transparent 55%), radial-gradient(circle at 80% 20%, rgba(240,165,0,.15) 0%, transparent 45%);
                pointer-events: none;
            }

            .dates-hero .icon-wrap {
                width: 72px;
                height: 72px;
                border-radius: 50%;
                background: rgba(255,255,255,.12);
                backdrop-filter: blur(6px);
                border: 2px solid rgba(255,255,255,.25);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 2rem;
                margin: 0 auto 1.25rem;
                animation: pulse-ring 2.4s ease-in-out infinite;
            }

        @@keyframes pulse-ring {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(255,255,255,.35);
            }

            50% {
                box-shadow: 0 0 0 14px rgba(255,255,255,0);
            }
        }

        .dates-hero h1 {
            font-family: 'Cairo', sans-serif;
            font-weight: 900;
            font-size: clamp(1.8rem, 4vw, 2.8rem);
            color: #fff;
            text-align: center;
            letter-spacing: -.5px;
        }

        .dates-hero p {
            color: rgba(255,255,255,.75);
            text-align: center;
            font-size: 1.05rem;
            margin-top: .5rem;
        }

        /* ── Card wrapper ── */
        .dates-card {
            background: #fff;
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
            margin-top: -2.5rem;
            position: relative;
            z-index: 10;
        }

        /* ── Table ── */
        .dates-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            font-size: .97rem;
        }

            .dates-table thead th {
                background: var(--brand-mid);
                color: #fff;
                font-family: 'Cairo', sans-serif;
                font-weight: 700;
                font-size: 1rem;
                padding: 1rem 1.5rem;
                text-align: center;
                border: none;
                white-space: nowrap;
            }

                .dates-table thead th:first-child {
                    text-align: right;
                    border-radius: 0;
                }

                .dates-table thead th:last-child {
                    border-radius: 0;
                }

            /* Gold accent on header top border */
            .dates-table thead tr {
                border-top: 3px solid var(--brand-gold);
            }

            .dates-table tbody tr {
                transition: background .18s ease, transform .18s ease;
            }

                .dates-table tbody tr:nth-child(even) {
                    background: var(--brand-light);
                }

                .dates-table tbody tr:nth-child(odd) {
                    background: #fff;
                }

                .dates-table tbody tr:hover {
                    background: #d6eaff !important;
                    transform: scale(1.005);
                    box-shadow: inset 3px 0 0 var(--brand-accent);
                }

            .dates-table tbody td {
                padding: .95rem 1.5rem;
                border-bottom: 1px solid #e2eaf4;
                vertical-align: middle;
            }

                /* Category cell */
                .dates-table tbody td.cat-cell {
                    font-family: 'Cairo', sans-serif;
                    font-weight: 700;
                    font-size: 1rem;
                    color: var(--brand-mid);
                    text-align: right;
                }

                /* Date cells */
                .dates-table tbody td.date-cell {
                    text-align: center;
                    font-size: .95rem;
                    color: var(--text-main);
                    direction: ltr; /* keep dates LTR */
                    font-variant-numeric: tabular-nums;
                }

        /* Badge pill for category */
        .cat-badge {
            display: inline-flex;
            align-items: center;
            gap: .45rem;
        }

            .cat-badge .dot {
                width: 9px;
                height: 9px;
                border-radius: 50%;
                flex-shrink: 0;
                background: var(--brand-accent);
            }

            .cat-badge.female .dot {
                background: #e84393;
            }

            .cat-badge.research .dot {
                background: var(--brand-gold);
            }

        /* Date chip */
        .date-chip {
            display: inline-block;
            background: var(--brand-light);
            color: var(--brand-mid);
            font-weight: 600;
            padding: .3rem .8rem;
            border-radius: 6px;
            border: 1px solid #c8ddf2;
            font-size: .9rem;
            transition: background .18s;
        }

        tr:hover .date-chip {
            background: #b8d4f0;
        }

        /* ── Footer note ── */
        .dates-footer {
            padding: 1.25rem 1.5rem;
            background: #f8fbff;
            border-top: 1px solid #e2eaf4;
            display: flex;
            align-items: center;
            gap: .6rem;
            color: var(--text-muted);
            font-size: .88rem;
        }

            .dates-footer svg {
                flex-shrink: 0;
                color: var(--brand-accent);
            }

        /* ── Responsive ── */
        @@media (max-width: 576px) {
            .dates-table thead th, .dates-table tbody td {
                padding: .75rem .9rem;
                font-size: .88rem;
            }

            .date-chip {
                padding: .25rem .55rem;
                font-size: .82rem;
            }
        }

        /* ── Entrance animations ── */
        .animate-in {
            opacity: 0;
            transform: translateY(22px);
            animation: slide-up .55s cubic-bezier(.22,1,.36,1) forwards;
        }

            .animate-in:nth-child(1) {
                animation-delay: .05s;
            }

            .animate-in:nth-child(2) {
                animation-delay: .12s;
            }

            .animate-in:nth-child(3) {
                animation-delay: .19s;
            }

            .animate-in:nth-child(4) {
                animation-delay: .26s;
            }

            .animate-in:nth-child(5) {
                animation-delay: .33s;
            }

        @@keyframes slide-up {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <section class="dates-hero">
        <div class="icon-wrap">📅</div>
        <h1>مواعيد التسجيل</h1>
        <p>العام الدراسي 2025 – 2026</p>
    </section>

    <div class="container py-4">
        <div class="dates-card">

            <div class="table-responsive">
                <table class="dates-table" id="datesTable">
                    <thead>
                        <tr>
                            <th style="text-align:right; padding-right:1.5rem;">الفئة</th>
                            <th>من</th>
                            <th>إلى</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="animate-in">
                            <td class="cat-cell">
                                <span class="cat-badge male">
                                    <span class="dot"></span>
                                    الطلاب الجدد
                                </span>
                            </td>
                            <td class="date-cell"><span class="date-chip">12/9/2025</span></td>
                            <td class="date-cell"><span class="date-chip">15/9/2025</span></td>
                        </tr>
                        <tr class="animate-in">
                            <td class="cat-cell">
                                <span class="cat-badge male">
                                    <span class="dot"></span>
                                    الطلاب القدامى
                                </span>
                            </td>
                            <td class="date-cell"><span class="date-chip">24/7/2025</span></td>
                            <td class="date-cell"><span class="date-chip">1/9/2025</span></td>
                        </tr>
                        <tr class="animate-in">
                            <td class="cat-cell">
                                <span class="cat-badge female">
                                    <span class="dot"></span>
                                    الطالبات الجدد
                                </span>
                            </td>
                            <td class="date-cell"><span class="date-chip">12/9/2025</span></td>
                            <td class="date-cell"><span class="date-chip">15/9/2025</span></td>
                        </tr>
                        <tr class="animate-in">
                            <td class="cat-cell">
                                <span class="cat-badge female">
                                    <span class="dot"></span>
                                    الطالبات القدامى
                                </span>
                            </td>
                            <td class="date-cell"><span class="date-chip">24/7/2025</span></td>
                            <td class="date-cell"><span class="date-chip">1/9/2025</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="dates-footer">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z" />
                </svg>
                جميع المواعيد خاضعة للتعديل – يُرجى متابعة الإعلانات الرسمية.
            </div>

        </div><!-- /.dates-card -->
    </div><!-- /.container -->
    <!-- Bootstrap JS bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
            crossorigin="anonymous"></script>

    <script>
        // Highlight rows that are "today" or in the near future
        document.addEventListener('DOMContentLoaded', () => {
            const today = new Date();
            today.setHours(0, 0, 0, 0);

            document.querySelectorAll('#datesTable tbody tr').forEach(row => {
                const chips = row.querySelectorAll('.date-chip');
                if (chips.length < 2) return;

                const parseDate = str => {
                    const [d, m, y] = str.split('/').map(Number);
                    return new Date(y, m - 1, d);
                };

                const from = parseDate(chips[0].textContent.trim());
                const to   = parseDate(chips[1].textContent.trim());

                if (today >= from && today <= to) {
                    row.style.background = '#fff9e6';
                    row.style.borderLeft = '4px solid #f0a500';
                    chips.forEach(c => {
                        c.style.background = '#fef3c7';
                        c.style.borderColor = '#f0a500';
                        c.style.color       = '#92400e';
                    });
                    const badge = row.querySelector('.cat-cell');
                    if (badge) {
                        const tag = document.createElement('span');
                        tag.textContent = 'جارٍ الآن';
                        tag.style.cssText =
                            'margin-right:.6rem;font-size:.75rem;background:#f0a500;color:#fff;' +
                            'padding:.15rem .55rem;border-radius:20px;font-family:Cairo,sans-serif;font-weight:700;';
                        badge.appendChild(tag);
                    }
                }
            });
        });
    </script>

</body>
</html>
