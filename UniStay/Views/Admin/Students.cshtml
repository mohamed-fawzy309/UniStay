@model UniStay.ViewModels.StudentsPageViewModel
@using UniStay.Models
@{
    ViewData["Title"] = "الطلاب المقبولون";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css"
          crossorigin="anonymous" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Tajawal:wght@400;500;700&display=swap"
          rel="stylesheet" />

    <style>
        :root {
            --blue: #3b82f6;
            --blue-light: #60a5fa;
            --blue-dim: rgba(59,130,246,.15);
            --dark: #0b0f1a;
            --dark-card: #111827;
            --dark-input: #1a2236;
            --dark-border: #1f2d45;
            --text-muted: #6b7a99;
            --text-main: #e2e8f5;
            --success: #10b981;
            --success-dim: rgba(16,185,129,.15);
            --warn-light: #fbbf24;
            --warn-dim: rgba(245,158,11,.15);
            --radius: 14px;
            --radius-sm: 8px;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: var(--dark);
            color: var(--text-main);
            min-height: 100vh;
            direction: rtl;
        }

        .bg-grid {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            background-image: linear-gradient(var(--dark-border) 1px, transparent 1px), linear-gradient(90deg, var(--dark-border) 1px, transparent 1px);
            background-size: 48px 48px;
            opacity: .25;
        }

        .page-wrap {
            position: relative;
            z-index: 1;
            padding: 2.5rem 1.5rem 5rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        /* ── Header ── */
        .page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 2rem;
            animation: fade-down .55s cubic-bezier(.22,1,.36,1) both;
        }

            .page-header h1 {
                font-family: 'Cairo', sans-serif;
                font-weight: 900;
                font-size: clamp(1.5rem, 3vw, 2.2rem);
            }

                .page-header h1 span {
                    color: var(--success);
                }

            .page-header p {
                color: var(--text-muted);
                font-size: .95rem;
                margin-top: .3rem;
            }

        /* ── Stat strip ── */
        .stat-strip {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 1.75rem;
            animation: fade-up .5s cubic-bezier(.22,1,.36,1) .05s both;
        }

        .stat-chip {
            background: var(--dark-card);
            border: 1px solid var(--dark-border);
            border-radius: var(--radius);
            padding: 1rem 1.5rem;
            display: flex;
            align-items: center;
            gap: .85rem;
            flex: 1;
            min-width: 160px;
        }

        .stat-chip-icon {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            background: var(--success-dim);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .stat-chip-val {
            font-family: 'Cairo', sans-serif;
            font-weight: 900;
            font-size: 1.5rem;
            color: var(--success);
            line-height: 1;
        }

        .stat-chip-lbl {
            font-size: .78rem;
            color: var(--text-muted);
            margin-top: .15rem;
        }

        /* ── Toolbar ── */
        .toolbar {
            display: flex;
            align-items: center;
            gap: .75rem;
            flex-wrap: wrap;
            margin-bottom: 1.25rem;
            animation: fade-up .5s cubic-bezier(.22,1,.36,1) .1s both;
        }

        .search-wrap {
            position: relative;
            flex: 1;
            min-width: 220px;
        }

        .search-icon {
            position: absolute;
            top: 50%;
            right: .9rem;
            transform: translateY(-50%);
            color: var(--text-muted);
            pointer-events: none;
        }

        .search-input {
            width: 100%;
            background: var(--dark-input);
            border: 1.5px solid var(--dark-border);
            border-radius: var(--radius-sm);
            color: var(--text-main);
            font-family: 'Tajawal', sans-serif;
            font-size: .95rem;
            padding: .7rem 2.5rem .7rem 1rem;
            outline: none;
            transition: border-color .2s, box-shadow .2s;
            direction: rtl;
        }

            .search-input::placeholder {
                color: var(--text-muted);
            }

            .search-input:focus {
                border-color: var(--blue);
                box-shadow: 0 0 0 3px var(--blue-dim);
            }

        .select-filter {
            background: var(--dark-input);
            border: 1.5px solid var(--dark-border);
            border-radius: var(--radius-sm);
            color: var(--text-main);
            font-family: 'Tajawal', sans-serif;
            font-size: .93rem;
            padding: .7rem 1rem;
            outline: none;
            cursor: pointer;
            transition: border-color .2s;
            direction: rtl;
            min-width: 180px;
        }

            .select-filter:focus {
                border-color: var(--blue);
                box-shadow: 0 0 0 3px var(--blue-dim);
            }

            .select-filter option {
                background: var(--dark-card);
            }

        .btn-go {
            background: var(--blue);
            border: none;
            border-radius: var(--radius-sm);
            color: #fff;
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .9rem;
            padding: .7rem 1.4rem;
            cursor: pointer;
            transition: background .2s, transform .15s;
            white-space: nowrap;
        }

            .btn-go:hover {
                background: var(--blue-light);
                transform: translateY(-1px);
            }

        .btn-clear {
            background: var(--dark-input);
            border: 1px solid var(--dark-border);
            border-radius: var(--radius-sm);
            color: var(--text-muted);
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .88rem;
            padding: .7rem 1rem;
            cursor: pointer;
            transition: border-color .2s, color .2s;
            text-decoration: none;
            display: inline-block;
        }

            .btn-clear:hover {
                border-color: var(--text-muted);
                color: var(--text-main);
            }

        /* ── Table card ── */
        .table-card {
            background: var(--dark-card);
            border: 1px solid var(--dark-border);
            border-radius: var(--radius);
            overflow: hidden;
            animation: fade-up .55s cubic-bezier(.22,1,.36,1) .15s both;
        }

        .table-header-bar {
            padding: 1.1rem 1.5rem;
            border-bottom: 1px solid var(--dark-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: .5rem;
        }

        .table-title {
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: 1rem;
            display: flex;
            align-items: center;
            gap: .5rem;
        }

        .result-badge {
            font-size: .78rem;
            color: var(--text-muted);
            background: var(--dark-input);
            border: 1px solid var(--dark-border);
            padding: .2rem .65rem;
            border-radius: 20px;
        }

        .table-responsive-wrap {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 900px;
        }

        thead th {
            background: var(--dark-input);
            border-bottom: 1px solid var(--dark-border);
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .75rem;
            letter-spacing: .06em;
            color: var(--text-muted);
            text-transform: uppercase;
            padding: .8rem 1rem;
            white-space: nowrap;
            text-align: right;
        }

        tbody tr {
            border-bottom: 1px solid rgba(31,45,69,.6);
            transition: background .15s;
        }

            tbody tr:last-child {
                border-bottom: none;
            }

            tbody tr:hover {
                background: rgba(16,185,129,.03);
            }

        td {
            padding: .95rem 1rem;
            font-size: .9rem;
            vertical-align: middle;
            text-align: right;
        }

        .td-name {
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .95rem;
        }

        .td-sub {
            font-size: .75rem;
            color: var(--text-muted);
            margin-top: .12rem;
        }

        .national-id {
            font-family: monospace;
            font-size: .85rem;
            color: var(--blue-light);
            letter-spacing: .04em;
            direction: ltr;
            display: inline-block;
        }

        .accepted-pill {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .75rem;
            padding: .25rem .7rem;
            border-radius: 20px;
            background: var(--success-dim);
            color: var(--success);
            border: 1px solid rgba(16,185,129,.3);
            white-space: nowrap;
        }

        .dot-green {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--success);
            flex-shrink: 0;
            animation: blink 2s ease-in-out infinite;
        }

        .room-badge {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            font-size: .8rem;
            color: var(--warn-light);
            background: var(--warn-dim);
            border: 1px solid rgba(245,158,11,.3);
            border-radius: var(--radius-sm);
            padding: .2rem .6rem;
            white-space: nowrap;
        }

        .no-room {
            font-size: .8rem;
            color: var(--text-muted);
            font-style: italic;
        }

        .btn-details {
            background: var(--blue-dim);
            color: var(--blue-light);
            border: 1px solid rgba(59,130,246,.3);
            border-radius: var(--radius-sm);
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .78rem;
            padding: .4rem .9rem;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            transition: opacity .2s, transform .15s;
        }

            .btn-details:hover {
                opacity: .85;
                transform: translateY(-1px);
            }

        /* ── Empty state ── */
        .empty-state {
            text-align: center;
            padding: 4.5rem 2rem;
            color: var(--text-muted);
        }

            .empty-state .empty-icon {
                font-size: 3rem;
                display: block;
                margin-bottom: 1rem;
            }

            .empty-state h3 {
                font-family: 'Cairo', sans-serif;
                font-weight: 800;
                font-size: 1.1rem;
                color: var(--text-main);
                margin-bottom: .4rem;
            }

        /* ══ DETAILS MODAL ══ */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.72);
            backdrop-filter: blur(4px);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }

            .modal-overlay.open {
                display: flex;
            }

        .modal-box {
            background: var(--dark-card);
            border: 1px solid var(--dark-border);
            border-radius: var(--radius);
            width: 100%;
            max-width: 660px;
            max-height: 90vh;
            overflow-y: auto;
            animation: pop-in .3s cubic-bezier(.22,1,.36,1) both;
        }

        .modal-head {
            padding: 1.2rem 1.5rem;
            border-bottom: 1px solid var(--dark-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            background: var(--dark-card);
            z-index: 1;
        }

            .modal-head h2 {
                font-family: 'Cairo', sans-serif;
                font-weight: 900;
                font-size: 1.05rem;
            }

        .modal-close {
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            font-size: 1.5rem;
            line-height: 1;
            transition: color .2s;
        }

            .modal-close:hover {
                color: var(--text-main);
            }

        .modal-body {
            padding: 1.5rem;
        }

        .detail-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: .8rem;
        }

        @@media (max-width: 500px) {
            .detail-grid {
                grid-template-columns: 1fr;
            }
        }

        .detail-item {
            background: var(--dark-input);
            border: 1px solid var(--dark-border);
            border-radius: var(--radius-sm);
            padding: .7rem .95rem;
        }

        .detail-label {
            font-size: .7rem;
            color: var(--text-muted);
            font-weight: 600;
            letter-spacing: .06em;
            margin-bottom: .18rem;
        }

        .detail-value {
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .92rem;
        }

            .detail-value.blue {
                color: var(--blue-light);
            }

            .detail-value.green {
                color: var(--success);
            }

            .detail-value.amber {
                color: var(--warn-light);
            }

        .section-sep {
            font-family: 'Cairo', sans-serif;
            font-weight: 700;
            font-size: .75rem;
            color: var(--text-muted);
            letter-spacing: .08em;
            text-transform: uppercase;
            padding: .4rem 0 .25rem;
            border-bottom: 1px solid var(--dark-border);
            margin: .9rem 0 .65rem;
            grid-column: 1 / -1;
        }

        .allocation-banner {
            background: var(--success-dim);
            border: 1px solid rgba(16,185,129,.25);
            border-radius: var(--radius-sm);
            padding: .85rem 1.1rem;
            display: flex;
            align-items: center;
            gap: .75rem;
            margin-bottom: 1.25rem;
        }

        .allocation-banner-icon {
            font-size: 1.4rem;
            flex-shrink: 0;
        }

        .allocation-banner-text {
            font-size: .88rem;
            color: var(--success);
            line-height: 1.6;
        }

            .allocation-banner-text strong {
                font-family: 'Cairo', sans-serif;
                font-weight: 700;
                display: block;
            }

        .no-allocation-banner {
            background: var(--warn-dim);
            border: 1px solid rgba(245,158,11,.25);
            border-radius: var(--radius-sm);
            padding: .85rem 1.1rem;
            display: flex;
            align-items: center;
            gap: .75rem;
            margin-bottom: 1.25rem;
        }

        .no-allocation-banner-text {
            font-size: .88rem;
            color: var(--warn-light);
        }

        /* Animations */
        @@keyframes fade-down {
            from {
                opacity: 0;
                transform: translateY(-16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fade-up {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes pop-in {
            from {
                opacity: 0;
                transform: scale(.94) translateY(16px);
            }

            to {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }

        @@keyframes blink {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: .3;
            }
        }
    </style>
</head>
<body>

    <div class="bg-grid" aria-hidden="true"></div>

    <div class="page-wrap">

        <!-- Page Header -->
        <div class="page-header">
            <div>
                <h1>الطلاب <span>المقبولون</span></h1>
                <p>جميع الطلاب الذين تم قبولهم في السكن الجامعي</p>
            </div>
            <a href="@Url.Action("Acceptances","Admin")"
               style="background:var(--dark-input);border:1px solid var(--dark-border);border-radius:var(--radius-sm);
                  color:var(--text-muted);font-family:'Cairo',sans-serif;font-weight:700;font-size:.88rem;
                  padding:.65rem 1.2rem;text-decoration:none;display:inline-flex;align-items:center;gap:.4rem;
                  transition:color .2s,border-color .2s;"
               onmouseover="this.style.color='var(--text-main)';this.style.borderColor='var(--text-muted)'"
               onmouseout="this.style.color='var(--text-muted)';this.style.borderColor='var(--dark-border)'">
                ← إدارة الطلبات
            </a>
        </div>

        <!-- Stat Strip -->
        <div class="stat-strip">
            <div class="stat-chip">
                <div class="stat-chip-icon">✅</div>
                <div>
                    <div class="stat-chip-val">@Model.TotalCount</div>
                    <div class="stat-chip-lbl">إجمالي الطلاب المقبولين</div>
                </div>
            </div>
            <div class="stat-chip">
                <div class="stat-chip-icon" style="background:var(--blue-dim)">🏠</div>
                <div>
                    <div class="stat-chip-val" style="color:var(--blue-light)">
                        @Model.Students.Count(s => s.RoomNumber != null)
                    </div>
                    <div class="stat-chip-lbl">تم تخصيص غرفة لهم</div>
                </div>
            </div>
            <div class="stat-chip">
                <div class="stat-chip-icon" style="background:var(--warn-dim)">⏳</div>
                <div>
                    <div class="stat-chip-val" style="color:var(--warn-light)">
                        @Model.Students.Count(s => s.RoomNumber == null)
                    </div>
                    <div class="stat-chip-lbl">في انتظار تخصيص غرفة</div>
                </div>
            </div>
        </div>

        <!-- Toolbar -->
        <form method="get" action="@Url.Action("Students","Admin")">
            <div class="toolbar">
                <div class="search-wrap">
                    <span class="search-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none"
                             viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8" />
                            <line x1="21" y1="21" x2="16.65" y2="16.65" />
                        </svg>
                    </span>
                    <input type="text" name="search" class="search-input"
                           placeholder="ابحث بالاسم أو الرقم القومي أو الكود..."
                           value="@Model.SearchTerm" />
                </div>

                <select name="faculty" class="select-filter">
                    <option value="">— كل الكليات —</option>
                    @foreach (var f in Model.Faculties)
                    {
                        if (f == Model.FacultyFilter)
                        {
                            <option value="@f" selected>@f</option>
                        }
                        else
                        {
                            <option value="@f">@f</option>
                        }
                    }
                </select>

                <button type="submit" class="btn-go">بحث</button>

                @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.FacultyFilter))
                {
                    <a href="@Url.Action("Students","Admin")" class="btn-clear">مسح</a>
                }
            </div>
        </form>

        <!-- Table -->
        <div class="table-card">
            <div class="table-header-bar">
                <span class="table-title">
                    ✅ الطلاب المقبولون
                    <span class="result-badge">@Model.Students.Count نتيجة</span>
                </span>
                @if (!string.IsNullOrEmpty(Model.FacultyFilter))
                {
                    <span style="font-size:.82rem;color:var(--blue-light);">
                        📚 @Model.FacultyFilter
                    </span>
                }
            </div>

            <div class="table-responsive-wrap">
                @if (Model.Students.Count == 0)
                {
                    <div class="empty-state">
                        <span class="empty-icon">🔍</span>
                        <h3>لا توجد نتائج</h3>
                        <p>لا يوجد طلاب مقبولون مطابقون لمعايير البحث الحالية.</p>
                    </div>
                }
                else
                {
                    <table>
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>الطالب</th>
                                <th>الرقم القومي</th>
                                <th>الكلية / الفرقة</th>
                                <th>الغرفة المخصصة</th>
                                <th>تاريخ القبول</th>
                                <th>الحالة</th>
                                <th>تفاصيل</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int rowNum = 0;
                            }
                            @foreach (var s in Model.Students)
                            {
                                rowNum++;
                                <tr>
                                    <td style="color:var(--text-muted);font-size:.8rem;">@rowNum</td>

                                    <td>
                                        <div class="td-name">@(s.Name ?? "—")</div>
                                        <div class="td-sub">
                                            @(s.StudentCode ?? "")
                                            @if (!string.IsNullOrEmpty(s.StudentCode) && !string.IsNullOrEmpty(s.Email))
                                            {
                                                <text> &nbsp;|&nbsp; </text>
                                            }
                                            @(s.Email ?? s.Mobile ?? "")
                                        </div>
                                    </td>

                                    <td><span class="national-id">@(s.NationalId ?? "—")</span></td>

                                    <td>
                                        <div style="font-size:.88rem;">@(s.Faculty ?? "—")</div>
                                        <div class="td-sub">@(s.Grade ?? "—")&nbsp;|&nbsp;@(s.StudyType ?? "—")</div>
                                    </td>

                                    <td>
                                        @if (s.RoomNumber != null)
                                        {
                                            <span class="room-badge">
                                                🏠 @s.BuildingName — غرفة @s.RoomNumber
                                                @if (s.BedNumber.HasValue)
                                                {
                                                    <text>/ سرير @s.BedNumber</text>
                                                }
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="no-room">لم تُخصَّص بعد</span>
                                        }
                                    </td>

                                    <td style="font-size:.83rem;color:var(--text-muted);white-space:nowrap;">
                                        @(s.ReviewedAt.HasValue ? s.ReviewedAt.Value.ToString("dd/MM/yyyy") : "—")
                                    </td>

                                    <td>
                                        <span class="accepted-pill">
                                            <span class="dot-green"></span>مقبول
                                        </span>
                                    </td>

                                    <td>
                                        <button class="btn-details"
                                                onclick="openDetails(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(s)))">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none"
                                                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <circle cx="12" cy="12" r="10" />
                                                <line x1="12" y1="8" x2="12" y2="12" />
                                                <line x1="12" y1="16" x2="12.01" y2="16" />
                                            </svg>
                                            تفاصيل
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>

    </div>
    <!-- /page-wrap -->
    <!-- ══════════════════════════════════
         DETAILS MODAL
    ══════════════════════════════════ -->
    <div class="modal-overlay" id="detailsModal" onclick="closeOnBackdrop(event)">
        <div class="modal-box" onclick="event.stopPropagation()">
            <div class="modal-head">
                <h2>✅ بيانات الطالب المقبول</h2>
                <button class="modal-close" onclick="closeModal()">×</button>
            </div>
            <div class="modal-body" id="modalBody"></div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
            crossorigin="anonymous"></script>
    <script>
        function closeModal()   { document.getElementById('detailsModal').classList.remove('open'); }
        function closeOnBackdrop(e) { if (e.target === document.getElementById('detailsModal')) closeModal(); }

        function openDetails(s) {
            const fmt  = v => v ?? '—';
            const bool = v => v === true ? 'نعم' : v === false ? 'لا' : '—';
            const date = v => v ? new Date(v).toLocaleDateString('ar-EG') : '—';

            const allocationBanner = s.roomNumber
                ? `<div class="allocation-banner">
                       <div class="allocation-banner-icon">🏠</div>
                       <div class="allocation-banner-text">
                           <strong>تم تخصيص غرفة لهذا الطالب</strong>
                           ${fmt(s.buildingName)} — غرفة ${fmt(s.roomNumber)}
                           ${s.bedNumber ? '/ سرير ' + s.bedNumber : ''}
                           ${s.academicYear ? ' | ' + s.academicYear : ''}
                       </div>
                   </div>`
                : `<div class="no-allocation-banner">
                       <div class="allocation-banner-icon">⏳</div>
                       <div class="no-allocation-banner-text">لم يتم تخصيص غرفة لهذا الطالب بعد.</div>
                   </div>`;

            document.getElementById('modalBody').innerHTML = `
                ${allocationBanner}
                <div class="detail-grid">
                    <div class="section-sep">البيانات الشخصية</div>
                    <div class="detail-item"><div class="detail-label">الاسم الكامل</div><div class="detail-value">${fmt(s.name)}</div></div>
                    <div class="detail-item"><div class="detail-label">الرقم القومي</div><div class="detail-value blue" style="direction:ltr;text-align:right">${fmt(s.nationalId)}</div></div>
                    <div class="detail-item"><div class="detail-label">كود الطالب</div><div class="detail-value blue">${fmt(s.studentCode)}</div></div>
                    <div class="detail-item"><div class="detail-label">الجنس</div><div class="detail-value">${fmt(s.gender)}</div></div>
                    <div class="detail-item"><div class="detail-label">تاريخ الميلاد</div><div class="detail-value">${date(s.birthDate)}</div></div>
                    <div class="detail-item"><div class="detail-label">الجنسية</div><div class="detail-value">${fmt(s.nationality)}</div></div>

                    <div class="section-sep">بيانات الدراسة</div>
                    <div class="detail-item"><div class="detail-label">الكلية</div><div class="detail-value">${fmt(s.faculty)}</div></div>
                    <div class="detail-item"><div class="detail-label">الفرقة</div><div class="detail-value">${fmt(s.grade)}</div></div>
                    <div class="detail-item"><div class="detail-label">نوع الدراسة</div><div class="detail-value">${fmt(s.studyType)}</div></div>
                    <div class="detail-item"><div class="detail-label">نوع السكن</div><div class="detail-value">${fmt(s.housingType)}</div></div>

                    <div class="section-sep">التواصل والأسرة</div>
                    <div class="detail-item"><div class="detail-label">البريد الإلكتروني</div><div class="detail-value">${fmt(s.email)}</div></div>
                    <div class="detail-item"><div class="detail-label">الجوال</div><div class="detail-value">${fmt(s.mobile)}</div></div>
                    <div class="detail-item"><div class="detail-label">اسم الأب</div><div class="detail-value">${fmt(s.fatherName)}</div></div>
                    <div class="detail-item"><div class="detail-label">هاتف الأب</div><div class="detail-value">${fmt(s.fatherPhone)}</div></div>
                    <div class="detail-item"><div class="detail-label">ذوي احتياجات خاصة</div><div class="detail-value">${bool(s.specialNeeds)}</div></div>
                    <div class="detail-item"><div class="detail-label">الأسرة في الخارج</div><div class="detail-value">${bool(s.familyAbroad)}</div></div>

                    <div class="section-sep">بيانات القبول</div>
                    <div class="detail-item"><div class="detail-label">تاريخ القبول</div><div class="detail-value green">${date(s.reviewedAt)}</div></div>
                    <div class="detail-item"><div class="detail-label">تم القبول بواسطة</div><div class="detail-value">${fmt(s.reviewedBy)}</div></div>
                    ${s.mealPlan ? `<div class="detail-item"><div class="detail-label">نظام الوجبات</div><div class="detail-value">${s.mealPlan}</div></div>` : ''}
                    ${s.adminRemarks ? `
                    <div class="detail-item" style="grid-column:1/-1">
                        <div class="detail-label">ملاحظات المشرف</div>
                        <div class="detail-value">${s.adminRemarks}</div>
                    </div>` : ''}
                </div>
            `;

            document.getElementById('detailsModal').classList.add('open');
        }
    </script>

</body>
</html>
